---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  withBase,
  SUPABASE_URL,
  SUPABASE_ANON_KEY,
  PRIVACY_POLICY_VERSION,
} from '../utils/site';
---

<BaseLayout title="회원가입" description="병원 AI 연구소 회원가입" noindex>
  <div class="container">
    <header class="page-head">
      <h1>회원가입</h1>
      <p class="lead">
        가입하면 회원 전용 <a href={withBase('/notes/')}>강의노트</a>를 볼 수
        있습니다. 필수 항목은 이름과 이메일뿐입니다.
      </p>
    </header>

    {
      !SUPABASE_URL ? (
        <p class="empty">회원 기능은 준비 중입니다. 조금만 기다려 주세요.</p>
      ) : (
        <div class="member-form">
          <div class="oauth-buttons">
            <button type="button" class="btn oauth google" id="oauth-google">Google로 계속하기</button>
            <button type="button" class="btn oauth kakao" id="oauth-kakao">카카오로 계속하기</button>
          </div>
          <p class="hint" id="oauth-status"></p>
          <div class="divider"><span>또는 이메일로 가입</span></div>

        <form id="signup-form" novalidate>
          <label>이름 <span class="req">필수</span><input type="text" id="f-name" autocomplete="name" required /></label>
          <label>이메일 <span class="req">필수</span><input type="email" id="f-email" autocomplete="email" required /></label>
          <label>비밀번호 <span class="req">필수</span> <span class="small">(8자 이상)</span><input type="password" id="f-password" autocomplete="new-password" minlength="8" required /></label>
          <label>비밀번호 확인 <span class="req">필수</span><input type="password" id="f-password2" autocomplete="new-password" required /></label>

          <details class="optional">
            <summary>선택 항목</summary>
            <label>성별
              <select id="f-gender">
                <option value="">선택 안 함</option>
                <option value="여성">여성</option>
                <option value="남성">남성</option>
              </select>
            </label>
            <label>생년월일<input type="date" id="f-birth" /></label>
            <label>휴대폰번호<input type="tel" id="f-phone" placeholder="010-0000-0000" autocomplete="tel" /></label>
          </details>

          <div class="consents">
            <label class="check all-agree">
              <input type="checkbox" id="c-all" />
              <span><strong>전체 동의</strong></span>
            </label>
            <hr class="consent-divider" />
            <label class="check">
              <input type="checkbox" id="c-age" />
              <span><strong>[필수]</strong> 만 14세 이상입니다.</span>
            </label>
            <label class="check">
              <input type="checkbox" id="c-required" />
              <span>
                <strong>[필수]</strong> 개인정보 수집·이용에 동의합니다.
                <span class="small">
                  (항목: 이름, 이메일, 비밀번호 / 목적: 회원 관리, 회원 전용
                  콘텐츠 제공 / 보유: 탈퇴 시까지 / 동의를 거부할 권리가
                  있으나, 거부 시 회원가입이 불가합니다 —
                  <a href={withBase('/privacy/')} target="_blank">처리방침 전문</a>)
                </span>
              </span>
            </label>
            <label class="check">
              <input type="checkbox" id="c-optional" />
              <span>
                <strong>[선택]</strong> 선택 항목(성별, 생년월일, 휴대폰번호)
                수집·이용에 동의합니다.
                <span class="small">
                  (목적: 콘텐츠 개선을 위한 통계 / 보유: 탈퇴 시까지 / 동의하지
                  않아도 가입할 수 있습니다)
                </span>
              </span>
            </label>
          </div>

          <button class="btn" type="submit" id="f-submit">가입하기</button>
          <p class="hint" id="f-status"></p>
          <p class="hint">이미 회원이신가요? <a href={withBase('/login/')}>로그인</a></p>
        </form>
        </div>
      )
    }
  </div>
</BaseLayout>

<script
  is:inline
  define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY, PRIVACY_POLICY_VERSION }}
>
  (async () => {
    if (!SUPABASE_URL) return;
    const { createClient } = await import(
      'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.0/+esm'
    );
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    const $ = (id) => document.getElementById(id);
    const loginUrl = new URL('../login/', location.href).href;

    // 구글·카카오는 로그인 페이지의 관문(동의 확인)으로 돌아가게 한다
    async function startOAuth(provider) {
      const status = $('oauth-status');
      status.textContent = `${provider === 'google' ? 'Google' : '카카오'}로 이동합니다…`;
      const { error } = await sb.auth.signInWithOAuth({
        provider,
        options: { redirectTo: loginUrl },
      });
      if (error) status.textContent = `로그인 실패: ${error.message}`;
    }
    $('oauth-google').addEventListener('click', () => startOAuth('google'));
    $('oauth-kakao').addEventListener('click', () => startOAuth('kakao'));

    // 실제로 켜져 있는 소셜 로그인만 활성화 (Supabase 설정 자동 반영)
    (async () => {
      try {
        const res = await fetch(`${SUPABASE_URL}/auth/v1/settings`, {
          headers: { apikey: SUPABASE_ANON_KEY },
        });
        const ext = (await res.json()).external || {};
        [['oauth-google', 'google'], ['oauth-kakao', 'kakao']].forEach(([id, key]) => {
          if (!ext[key]) {
            const b = $(id);
            b.disabled = true;
            b.classList.add('soon');
            b.append(document.createTextNode(' (준비 중)'));
          }
        });
      } catch {}
    })();

    // 전체 동의: 누르면 하위 항목을 모두 같은 상태로, 하위 항목을 개별
    // 조작하면 전체 동의 체크 상태를 다시 계산한다 (표준 "전체 동의" UX)
    const subChecks = [$('c-age'), $('c-required'), $('c-optional')];
    $('c-all').addEventListener('change', (e) => {
      subChecks.forEach((c) => (c.checked = e.target.checked));
    });
    subChecks.forEach((c) =>
      c.addEventListener('change', () => {
        $('c-all').checked = subChecks.every((sc) => sc.checked);
      })
    );

    $('signup-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = $('f-status');
      try {
        const name = $('f-name').value.trim();
        const email = $('f-email').value.trim();
        const pw = $('f-password').value;
        if (!name || !email) throw new Error('이름과 이메일을 입력해 주세요.');
        if (pw.length < 8) throw new Error('비밀번호는 8자 이상이어야 합니다.');
        if (pw !== $('f-password2').value) throw new Error('비밀번호 확인이 일치하지 않습니다.');
        if (!$('c-age').checked) throw new Error('만 14세 이상 확인에 체크해 주세요.');
        if (!$('c-required').checked) throw new Error('[필수] 개인정보 수집·이용 동의에 체크해 주세요.');

        const gender = $('f-gender').value || null;
        const birth = $('f-birth').value || null;
        const phone = $('f-phone').value.trim() || null;
        const hasOptional = !!(gender || birth || phone);
        if (hasOptional && !$('c-optional').checked)
          throw new Error('선택 항목을 입력하셨다면 [선택] 동의에 체크하거나, 선택 항목을 비워 주세요.');

        status.textContent = '가입 처리 중…';
        $('f-submit').disabled = true;

        // 동의 "여부"만 보낸다 — 동의 일시는 서버(DB 트리거)가 서버 시각으로 기록
        const { data, error } = await sb.auth.signUp({
          email,
          password: pw,
          options: {
            data: {
              name,
              gender: $('c-optional').checked ? gender : null,
              birth_date: $('c-optional').checked ? birth : null,
              phone: $('c-optional').checked ? phone : null,
              consent_required: true,
              consent_optional: !!($('c-optional').checked && hasOptional),
              policy_version: PRIVACY_POLICY_VERSION,
            },
          },
        });
        if (error) throw new Error(/already registered/i.test(error.message) ? '이미 가입된 이메일입니다. 로그인해 주세요.' : `가입 실패: ${error.message}`);
        // 이메일 인증 모드에서 기가입 이메일은 오류 대신 identities가 빈 배열로 온다
        if (data?.user && Array.isArray(data.user.identities) && data.user.identities.length === 0) {
          status.textContent = '이미 가입된 이메일입니다. 로그인하거나 비밀번호 재설정을 이용해 주세요.';
          return;
        }
        status.textContent = '확인 메일을 보냈습니다. 메일함에서 인증 링크를 누른 뒤 로그인해 주세요.';
      } catch (err) {
        status.textContent = err.message;
      } finally {
        $('f-submit').disabled = false;
      }
    });
  })();
</script>

<style>
  .member-form {
    max-width: 28rem;
    margin-top: 1rem;
    padding-bottom: 2rem;
  }

  #signup-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .btn.oauth {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .btn.oauth:hover {
    border-color: var(--color-primary);
  }

  .btn.oauth.kakao {
    background: #fee500;
    border-color: #fee500;
    color: #191600;
  }

  .btn.oauth.soon {
    opacity: 0.5;
    cursor: default;
    background: var(--color-surface);
    color: var(--color-muted);
    border-color: var(--color-border);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .req {
    color: var(--color-primary);
    font-size: 0.75rem;
  }

  .small {
    font-weight: 400;
    font-size: 0.8rem;
  }

  input,
  select {
    display: block;
    width: 100%;
    margin-top: 0.35rem;
    font: inherit;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.55rem 0.75rem;
  }

  .optional {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
  }

  .optional summary {
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .optional label {
    display: block;
    margin-top: 0.85rem;
  }

  .consents {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: 1.1rem 1.2rem;
  }

  .check {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-weight: 400;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .check input {
    width: auto;
    margin-top: 0.3rem;
  }

  .all-agree {
    font-weight: 600;
  }

  .all-agree span {
    color: var(--color-text);
  }

  .consent-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  .hint {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .empty {
    color: var(--color-muted);
  }
</style>
