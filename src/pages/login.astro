---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  withBase,
  SUPABASE_URL,
  SUPABASE_ANON_KEY,
  PRIVACY_POLICY_VERSION,
} from '../utils/site';

const privacyUrl = withBase('/privacy/');
---

<BaseLayout title="로그인" description="병원 AI 연구소 회원 로그인" noindex>
  <div class="container">
    <header class="page-head">
      <h1>로그인</h1>
    </header>

    {
      !SUPABASE_URL ? (
        <p class="empty">회원 기능은 준비 중입니다. 조금만 기다려 주세요.</p>
      ) : (
        <div class="member-form">
          <div id="login-area">
            <form id="login-form" novalidate>
              <label>이메일<input type="email" id="l-email" autocomplete="email" required /></label>
              <label>비밀번호<input type="password" id="l-password" autocomplete="current-password" required /></label>
              <button class="btn" type="submit" id="l-submit">로그인</button>
              <p class="hint" id="l-status"></p>
            </form>

            <div class="divider"><span>또는</span></div>

            <div class="oauth-buttons">
              <button type="button" class="btn oauth google" id="oauth-google">Google로 로그인</button>
              <button type="button" class="btn oauth kakao" id="oauth-kakao">카카오로 로그인</button>
            </div>

            <p class="hint">
              <a href="#" id="l-reset">비밀번호를 잊으셨나요?</a> ·
              <a href={withBase('/signup/')}>회원가입</a>
            </p>
          </div>

          <form id="recovery-form" hidden>
            <h2>새 비밀번호 설정</h2>
            <label>새 비밀번호 (8자 이상)<input type="password" id="r-password" autocomplete="new-password" minlength="8" /></label>
            <button class="btn" type="submit">변경</button>
            <p class="hint" id="r-status"></p>
          </form>

          <div id="oauth-consent" class="consent-panel" hidden>
            <h2>처음 로그인하셨네요</h2>
            <p class="hint">강의노트를 보시려면 아래 동의가 필요합니다.</p>
            <label class="check">
              <input type="checkbox" id="oc-age" />
              <span>[필수] 만 14세 이상입니다.</span>
            </label>
            <label class="check">
              <input type="checkbox" id="oc-consent" />
              <span>
                [필수] 개인정보 수집·이용에 동의합니다.
                <span class="small">
                  (항목: 이름, 이메일 / 목적: 회원 관리, 회원 전용 콘텐츠 제공
                  / 보유: 탈퇴 시까지 / 동의를 거부할 권리가 있으나, 거부 시
                  이용이 불가합니다 —
                  <a href={privacyUrl} target="_blank">처리방침 전문</a>)
                </span>
              </span>
            </label>
            <button class="btn" id="oc-submit">동의하고 계속하기</button>
            <p class="hint" id="oc-status"></p>
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>

<script
  is:inline
  define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY, PRIVACY_POLICY_VERSION }}
>
  (async () => {
    if (!SUPABASE_URL) return;
    const { createClient } = await import(
      'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.0/+esm'
    );
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    const $ = (id) => document.getElementById(id);
    const notesUrl = new URL('../notes/', location.href).pathname;
    const loginUrl = new URL('../login/', location.href).href;

    // 프로필의 동의 기록 여부만 확인한다 (없음/있음만 판단, 값 자체는 서버 트리거·RPC 전용)
    async function getConsentStatus(userId) {
      const { data, error } = await sb
        .from('profiles')
        .select('consent_required_at')
        .eq('id', userId)
        .maybeSingle();
      if (error) throw new Error(`회원 정보 확인 실패: ${error.message}`);
      return !!(data && data.consent_required_at);
    }

    // 이메일/비밀번호 로그인 또는 구글·카카오 인증 성공 후 공통으로 거치는 관문.
    // 동의 기록이 있으면 강의노트로, 없으면(=구글·카카오 최초 로그인) 동의 화면을 보여준다.
    async function afterAuth(userId) {
      const consented = await getConsentStatus(userId);
      if (consented) {
        location.href = notesUrl;
        return;
      }
      $('login-area').hidden = true;
      $('oauth-consent').hidden = false;
    }

    // 비밀번호 재설정 메일로 들어온 경우
    sb.auth.onAuthStateChange((event) => {
      if (event === 'PASSWORD_RECOVERY') {
        $('recovery-form').hidden = false;
        $('login-area').hidden = true;
      }
    });

    $('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = $('l-status');
      try {
        status.textContent = '로그인 중…';
        $('l-submit').disabled = true;
        const { data, error } = await sb.auth.signInWithPassword({
          email: $('l-email').value.trim(),
          password: $('l-password').value,
        });
        if (error)
          throw new Error(
            /confirm/i.test(error.message)
              ? '이메일 인증이 아직 안 됐습니다. 가입 확인 메일의 링크를 먼저 눌러 주세요.'
              : '이메일 또는 비밀번호가 올바르지 않습니다.'
          );
        status.textContent = '로그인 성공 — 확인 중…';
        await afterAuth(data.user.id);
      } catch (err) {
        status.textContent = err.message;
      } finally {
        $('l-submit').disabled = false;
      }
    });

    $('l-reset').addEventListener('click', async (e) => {
      e.preventDefault();
      const email = $('l-email').value.trim();
      const status = $('l-status');
      if (!email) {
        status.textContent = '이메일을 먼저 입력한 뒤 다시 눌러 주세요.';
        return;
      }
      const { error } = await sb.auth.resetPasswordForEmail(email, {
        redirectTo: location.origin + location.pathname,
      });
      status.textContent = error ? `재설정 메일 발송 실패: ${error.message}` : '비밀번호 재설정 메일을 보냈습니다.';
    });

    $('recovery-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = $('r-status');
      const pw = $('r-password').value;
      if (pw.length < 8) {
        status.textContent = '비밀번호는 8자 이상이어야 합니다.';
        return;
      }
      const { error } = await sb.auth.updateUser({ password: pw });
      if (error) {
        status.textContent = `변경 실패: ${error.message}`;
        return;
      }
      // 안내 문구("다시 로그인해 주세요")와 실제 상태를 일치시키기 위해 로그아웃
      await sb.auth.signOut();
      status.textContent = '비밀번호가 변경됐습니다. 다시 로그인해 주세요.';
      setTimeout(() => location.reload(), 1500);
    });

    async function startOAuth(provider) {
      const status = $('l-status');
      status.textContent = `${provider === 'google' ? 'Google' : '카카오'}로 이동합니다…`;
      const { error } = await sb.auth.signInWithOAuth({
        provider,
        options: { redirectTo: loginUrl },
      });
      if (error) status.textContent = `로그인 실패: ${error.message}`;
    }
    $('oauth-google').addEventListener('click', () => startOAuth('google'));
    $('oauth-kakao').addEventListener('click', () => startOAuth('kakao'));

    $('oc-submit').addEventListener('click', async () => {
      const status = $('oc-status');
      if (!$('oc-age').checked || !$('oc-consent').checked) {
        status.textContent = '필수 항목에 모두 체크해 주세요.';
        return;
      }
      status.textContent = '처리 중…';
      const { error } = await sb.rpc('record_consent', {
        p_policy_version: PRIVACY_POLICY_VERSION,
      });
      if (error) {
        status.textContent = `오류: ${error.message}`;
        return;
      }
      location.href = notesUrl;
    });

    // 구글·카카오 인증에서 돌아온 경우(또는 세션이 남아 있는 경우) 자동으로 관문 통과
    const {
      data: { session },
    } = await sb.auth.getSession();
    if (session) {
      try {
        await afterAuth(session.user.id);
      } catch (err) {
        $('l-status').textContent = err.message;
      }
    }
  })();
</script>

<style>
  .member-form {
    max-width: 26rem;
    padding-bottom: 2rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  input {
    display: block;
    width: 100%;
    margin-top: 0.35rem;
    font: inherit;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.55rem 0.75rem;
  }

  .btn {
    align-self: flex-start;
  }

  .hint {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  #recovery-form h2,
  #oauth-consent h2 {
    font-size: 1.1rem;
  }

  .empty {
    color: var(--color-muted);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .btn.oauth {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .btn.oauth:hover {
    border-color: var(--color-primary);
  }

  .btn.oauth.kakao {
    background: #fee500;
    border-color: #fee500;
    color: #191600;
  }

  .consent-panel {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
  }

  .check {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-weight: 400;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .check input {
    width: auto;
    margin-top: 0.3rem;
  }

  .small {
    font-weight: 400;
    font-size: 0.8rem;
  }
</style>
