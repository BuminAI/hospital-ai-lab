---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT_EMAIL } from '../utils/site';
---

<BaseLayout
  title="문의"
  description="병원 AI 연구소에 대한 문의는 이메일로 받고 있습니다."
>
  <div class="container">
    <header class="page-head">
      <h1>문의</h1>
      <p class="lead">
        연구 주제에 대한 의견, 협업 제안, 콘텐츠에 대한 질문 등 어떤 이야기든
        이메일로 보내주세요.
      </p>
    </header>

    <div class="email-card">
      <p class="label">이메일</p>
      <p class="email">{CONTACT_EMAIL}</p>
      <button type="button" class="btn" id="copy-email">메일 주소 복사</button>
      <p class="copy-hint">복사한 주소를 평소 쓰시는 메일 앱에 붙여넣어 보내주세요.</p>
      <p class="copy-status" id="copy-status" role="status" aria-live="polite"></p>
    </div>

    <section class="guide">
      <h2>메일을 보내실 때</h2>
      <ul>
        <li>소속과 성함을 간단히 알려주시면 답변에 도움이 됩니다.</li>
        <li>문의 내용은 구체적일수록 좋습니다. 관련 자료가 있다면 함께 보내주세요.</li>
        <li>답변까지는 다소 시간이 걸릴 수 있습니다. 너른 양해 부탁드립니다.</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<script is:inline define:vars={{ CONTACT_EMAIL }}>
  (() => {
    const btn = document.getElementById('copy-email');
    const status = document.getElementById('copy-status');
    if (!btn) return;
    const originalLabel = btn.textContent;
    let resetTimer;

    async function copyEmail() {
      try {
        await navigator.clipboard.writeText(CONTACT_EMAIL);
      } catch {
        // 클립보드 API를 쓸 수 없는 환경(구형 브라우저·비보안 접속) 대비 폴백
        const ta = document.createElement('textarea');
        ta.value = CONTACT_EMAIL;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
        } catch {
          status.textContent = '복사에 실패했습니다. 이메일 주소를 직접 선택해 복사해 주세요.';
          document.body.removeChild(ta);
          return;
        }
        document.body.removeChild(ta);
      }
      btn.textContent = '복사했습니다';
      status.textContent = `${CONTACT_EMAIL} 이(가) 클립보드에 복사됐습니다.`;
      clearTimeout(resetTimer);
      resetTimer = setTimeout(() => {
        btn.textContent = originalLabel;
      }, 2000);
    }

    btn.addEventListener('click', copyEmail);
  })();
</script>

<style>
  .email-card {
    margin-top: 1.5rem;
    max-width: var(--prose-width);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2.5rem 2.25rem;
    text-align: center;
  }

  .label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .email {
    margin-top: 0.5rem;
    font-size: clamp(1.25rem, 4vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    user-select: all;
  }

  .email-card .btn {
    margin-top: 1.75rem;
  }

  .copy-hint {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .copy-status {
    min-height: 1.2em;
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-primary);
  }

  .guide {
    margin-top: 3rem;
    max-width: var(--prose-width);
  }

  .guide h2 {
    font-size: 1.25rem;
    margin-bottom: 0.85rem;
  }

  .guide ul {
    margin: 0;
    padding-left: 1.4rem;
    color: var(--color-muted);
  }

  .guide li + li {
    margin-top: 0.4rem;
  }
</style>
