---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideRelated from '../components/GuideRelated.astro';
import { checklistIntro, checklistSections } from '../data/checklist';
---

<BaseLayout
  title="AI 도입 검토 체크리스트"
  description="병원 AI 의료기기·솔루션 도입 제안을 검토할 때 행정·간호 부서가 확인할 항목을 주제별로 정리한 일반 가이드입니다."
>
  <div class="container">
    <header class="page-head">
      <h1>AI 도입 검토 체크리스트</h1>
      <p class="lead">{checklistIntro}</p>
    </header>

    {
      checklistSections.map((section) => (
        <section class="section">
          <h2>{section.title}</h2>
          <ul class="checklist">
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }

    <GuideRelated current="checklist" />
  </div>
</BaseLayout>

<style>
  .section {
    margin-top: 2.75rem;
    max-width: var(--prose-width);
  }

  .section:first-of-type {
    margin-top: 2.5rem;
  }

  .section h2 {
    font-size: 1.3rem;
  }

  .checklist {
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .checklist li {
    position: relative;
    padding: 0.7rem 0 0.7rem 1.6rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .checklist li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .checklist li::before {
    content: '▢';
    position: absolute;
    left: 0;
    top: 0.7rem;
    color: var(--color-primary);
  }
</style>
