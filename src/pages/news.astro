---
import BaseLayout from '../layouts/BaseLayout.astro';
import news from '../data/news.json';

const fmtFull = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});
const fmtDay = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  month: 'long',
  day: 'numeric',
});
const fmtTime = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  hour: '2-digit',
  minute: '2-digit',
});

const updatedAt = fmtFull.format(new Date(news.updatedAt));
const items = news.items;
---

<BaseLayout
  title="AI 뉴스"
  description="병원·보건·의료 분야의 AI 관련 최신 기사를 매일 오전 7시에 자동으로 모아 보여드립니다."
>
  <div class="container">
    <header class="page-head">
      <h1>AI 뉴스</h1>
      <p class="lead">
        병원·보건·의료 분야의 AI 관련 기사를 매일 오전 7시에 자동으로
        모읍니다. 직전 24시간 동안 보도된 기사가 대상입니다.
      </p>
    </header>

    <p class="updated">
      마지막 업데이트: <time datetime={news.updatedAt}>{updatedAt}</time>
    </p>

    {
      items.length > 0 ? (
        <ul class="news-list">
          {items.map((item) => {
            const d = new Date(item.pubDate);
            return (
              <li>
                <a href={item.link} target="_blank" rel="noopener">
                  {item.title}
                </a>
                <span class="meta">
                  {item.source && <>{item.source} · </>}
                  <time datetime={item.pubDate}>
                    {fmtDay.format(d)} {fmtTime.format(d)}
                  </time>
                </span>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty">최근 24시간 사이에 수집된 기사가 없습니다.</p>
      )
    }

    <section class="notice">
      <p>
        이 목록은 구글 뉴스 검색을 통해 자동으로 수집한 것으로, 연구소의
        편집·추천 의견이 아닙니다. 제목을 누르면 해당 언론사의 기사로
        이동합니다.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .updated {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .news-list {
    margin: 1.75rem 0 0;
    padding: 0;
    list-style: none;
    max-width: 52rem;
  }

  .news-list li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .news-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .news-list a {
    color: var(--color-text);
    font-weight: 600;
    line-height: 1.5;
  }

  .news-list a:hover {
    color: var(--color-primary);
  }

  .meta {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .empty {
    margin-top: 1.75rem;
    color: var(--color-muted);
  }

  .notice {
    margin-top: 2.5rem;
    max-width: 52rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
</style>
