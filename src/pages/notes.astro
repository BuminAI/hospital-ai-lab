---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, SUPABASE_URL, SUPABASE_ANON_KEY } from '../utils/site';
---

<BaseLayout
  title="강의노트"
  description="병원 AI 연구소 회원 전용 강의노트입니다. 로그인 후 볼 수 있습니다."
>
  <div class="container">
    <header class="page-head">
      <h1>강의노트</h1>
      <p class="lead">회원 전용 학습 자료입니다. 로그인하면 열람할 수 있습니다.</p>
    </header>

    {
      !SUPABASE_URL ? (
        <p class="empty">회원 기능은 준비 중입니다. 조금만 기다려 주세요.</p>
      ) : (
        <div>
          <div id="guest" hidden>
            <p class="empty">
              강의노트는 회원에게만 공개됩니다.
              <a href={withBase('/login/')}>로그인</a>하거나
              <a href={withBase('/signup/')}>회원가입</a> 후 이용해 주세요.
            </p>
          </div>

          <div id="member" hidden>
            <div class="member-bar">
              <span id="member-name"></span>
              <label class="email-notify-toggle">
                <input type="checkbox" id="email-notify" />
                새 글 이메일 알림
              </label>
              <button class="btn ghost" id="logout">로그아웃</button>
            </div>
            <div id="notes-list" class="notes-list">불러오는 중…</div>
            <article id="note-view" hidden>
              <p class="note-nav"><a href="#" id="note-back-top">← 목록으로</a></p>
              <header class="note-head">
                <h2 id="note-title"></h2>
                <p class="note-date" id="note-date"></p>
              </header>
              <div class="prose" id="note-body"></div>
              <p class="note-nav"><a href="#" id="note-back">← 목록으로</a></p>
            </article>
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  (async () => {
    if (!SUPABASE_URL) return;
    const { createClient } = await import(
      'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.0/+esm'
    );
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    const $ = (id) => document.getElementById(id);

    // XSS 안전: 먼저 전부 이스케이프한 뒤 최소한의 마크다운만 변환
    function esc(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    function inline(s) {
      return s
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\[([^\]]+)\]\((https?:[^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
    }
    function renderMd(src) {
      const lines = esc(src).split(/\r?\n/);
      let html = '';
      let inList = false;
      for (const line of lines) {
        if (/^- /.test(line)) {
          if (!inList) { html += '<ul>'; inList = true; }
          html += `<li>${inline(line.slice(2))}</li>`;
          continue;
        }
        if (inList) { html += '</ul>'; inList = false; }
        if (/^### /.test(line)) html += `<h4>${inline(line.slice(4))}</h4>`;
        else if (/^## /.test(line)) html += `<h3>${inline(line.slice(3))}</h3>`;
        else if (line.trim() !== '') html += `<p>${inline(line)}</p>`;
      }
      if (inList) html += '</ul>';
      return html;
    }

    const fmtDate = (iso) =>
      new Date(iso).toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: 'long', day: 'numeric' });

    // 카드에 보여줄 본문 미리보기 — 마크다운 기호를 걷어내고 앞부분만 자른다
    function excerpt(md) {
      const text = md
        .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
        .replace(/[#*`>_-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      return text.length > 110 ? text.slice(0, 110) + '…' : text;
    }

    let notes = [];

    function showList() {
      $('note-view').hidden = true;
      $('notes-list').hidden = false;
    }

    function showNote(n) {
      $('note-title').textContent = n.title;
      $('note-date').textContent = fmtDate(n.created_at);
      $('note-body').innerHTML = renderMd(n.body);
      $('notes-list').hidden = true;
      $('note-view').hidden = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function loadNotes() {
      const { data, error } = await sb
        .from('lecture_notes')
        .select('id, title, body, created_at')
        .eq('published', true)
        .order('created_at', { ascending: false });
      const el = $('notes-list');
      if (error) {
        el.textContent = '강의노트를 불러오지 못했습니다: ' + error.message;
        return;
      }
      notes = data;
      if (!notes.length) {
        el.textContent = '아직 등록된 강의노트가 없습니다.';
        return;
      }
      const NEW_DAYS = 7 * 24 * 60 * 60 * 1000;
      el.innerHTML = notes
        .map((n, i) => {
          const isNew = Date.now() - new Date(n.created_at).getTime() < NEW_DAYS;
          return `<button class="card note-card" data-i="${i}">
            <span class="note-meta">
              ${isNew ? '<span class="chip">NEW</span>' : ''}
              <span class="note-kind">📚 강의노트</span>
              <time>${fmtDate(n.created_at)}</time>
            </span>
            <span class="note-title"></span>
            <span class="note-excerpt"></span>
            <span class="note-open">펼쳐 읽기 →</span>
          </button>`;
        })
        .join('');
      el.querySelectorAll('.note-card').forEach((b, i) => {
        b.querySelector('.note-title').textContent = notes[i].title;
        b.querySelector('.note-excerpt').textContent = excerpt(notes[i].body);
        b.addEventListener('click', () => showNote(notes[Number(b.dataset.i)]));
      });
    }

    const { data: { session } } = await sb.auth.getSession();
    if (!session) {
      $('guest').hidden = false;
      return;
    }
    // 프로필·동의 기록 확인 — 없으면 "노트 없음"과 구분되는 안내를 보여준다
    const { data: profile, error: pErr } = await sb
      .from('profiles')
      .select('id, consent_required_at, email_notify_new_post')
      .eq('id', session.user.id)
      .maybeSingle();
    if (pErr || !profile || !profile.consent_required_at) {
      $('guest').hidden = false;
      $('guest').querySelector('.empty').textContent = pErr
        ? `회원 정보 확인에 실패했습니다: ${pErr.message}`
        : '이 계정에는 가입 동의 기록이 없어 강의노트를 볼 수 없습니다. 로그아웃 후 다시 로그인하거나 운영자에게 문의해 주세요.';
      return;
    }
    $('member').hidden = false;
    const name = session.user.user_metadata?.name || session.user.email;
    $('member-name').textContent = `👋 ${name} 님`;
    $('logout').addEventListener('click', async () => {
      await sb.auth.signOut();
      location.reload();
    });
    // 새 글 이메일 알림 옵트인 — 회원가입 이후에도 언제든 여기서 켜고 끌 수 있다
    const emailNotify = $('email-notify');
    emailNotify.checked = !!profile.email_notify_new_post;
    emailNotify.addEventListener('change', async () => {
      const checked = emailNotify.checked;
      emailNotify.disabled = true;
      const { error } = await sb
        .from('profiles')
        .update({ email_notify_new_post: checked })
        .eq('id', session.user.id);
      emailNotify.disabled = false;
      if (error) {
        alert('저장하지 못했습니다: ' + error.message);
        emailNotify.checked = !checked;
      }
    });
    ['note-back', 'note-back-top'].forEach((id) =>
      $(id).addEventListener('click', (e) => {
        e.preventDefault();
        showList();
      })
    );
    loadNotes();
  })();
</script>

<style>
  .member-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: 52rem;
    margin-bottom: 1.75rem;
    padding: 0.75rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.95rem;
  }

  #member-name {
    font-weight: 700;
  }

  .email-notify-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    cursor: pointer;
  }

  .email-notify-toggle input {
    width: auto;
    accent-color: var(--color-primary);
  }

  .btn.ghost {
    background: var(--color-bg);
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    padding: 0.4rem 1rem;
  }

  #note-view {
    max-width: var(--prose-width);
  }

  .note-head {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  #note-view h2 {
    font-size: 1.6rem;
    line-height: 1.4;
  }

  .note-date {
    margin: 0.6rem 0 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  #note-view .prose {
    margin-bottom: 2.5rem;
  }

  .note-nav {
    margin-bottom: 1.25rem;
  }

  .note-nav a {
    font-weight: 600;
  }

  .empty {
    color: var(--color-muted);
  }
</style>

<style is:global>
  /* 강의노트 목록 카드는 JS(innerHTML)로 그려져 Astro 스코프드 스타일이
     적용되지 않는다(HANDOFF §6). 그래서 이 블록만 전역으로 선언하고,
     다른 페이지에 새지 않게 .notes-list 아래로만 한정한다. */
  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52rem;
    color: var(--color-muted);
  }

  .notes-list .note-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    width: 100%;
    text-align: left;
    font: inherit;
    color: var(--color-text);
    cursor: pointer;
  }

  .notes-list .note-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .notes-list .note-kind {
    font-weight: 600;
  }

  .notes-list .note-title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .notes-list .note-card:hover .note-title {
    color: var(--color-primary);
  }

  .notes-list .note-excerpt {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .notes-list .note-open {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }
</style>
