---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, SUPABASE_URL, SUPABASE_ANON_KEY } from '../utils/site';
---

<BaseLayout
  title="AI로 만든 앱"
  description="연구소장이 AI로 직접 만든 프로그램을 소개합니다. 목록은 누구나 볼 수 있고, 로그인하면 파일을 내려받을 수 있습니다."
>
  <div class="container">
    <header class="page-head">
      <h1>AI로 만든 앱</h1>
      <p class="lead">
        직접 AI로 만든 프로그램을 소개합니다. 어떤 것들이 있는지는 누구나
        볼 수 있고, 로그인하면 파일을 내려받을 수 있습니다.
      </p>
      <p class="shots-disclaimer">
        ※ 카드에 보이는 "앱 화면"·"결과물 화면" 스크린샷 속 수치·이름 등
        데이터는 사용법을 보여주기 위해 만든 예시(가상) 데이터이며, 실제
        환자·병원 데이터가 아닙니다.
      </p>
    </header>

    {
      !SUPABASE_URL ? (
        <p class="empty">회원 기능은 준비 중입니다. 조금만 기다려 주세요.</p>
      ) : (
        <div>
          <div id="guest-banner" hidden>
            <p class="empty">
              다운로드하려면 <a href={withBase('/login/')}>로그인</a>하거나
              <a href={withBase('/signup/')}>회원가입</a> 후 이용해 주세요.
            </p>
          </div>
          <div id="member-bar" class="member-bar" hidden>
            <span id="member-name"></span>
            <button class="btn ghost" id="logout">로그아웃</button>
          </div>
          <div id="apps-status" class="hint">불러오는 중…</div>
          <div id="apps-grid" class="apps-grid"></div>
          <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="스크린샷 크게 보기" hidden>
            <button class="lightbox-close" id="lightbox-close" aria-label="닫기">✕</button>
            <img id="lightbox-img" src="" alt="" />
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY, signupUrl: withBase('/signup/') }}>
  (async () => {
    if (!SUPABASE_URL) return;
    const { createClient } = await import(
      'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.0/+esm'
    );
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    const $ = (id) => document.getElementById(id);
    const esc = (s) =>
      String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function extBadge(name) {
      const m = /\.([a-z0-9]+)$/i.exec(name || '');
      return m ? m[1].toUpperCase() : '파일';
    }

    function fmtBytes(n) {
      if (n === null || n === undefined) return '';
      if (n < 1024) return n + 'B';
      if (n < 1024 * 1024) return (n / 1024).toFixed(0) + 'KB';
      return (n / 1024 / 1024).toFixed(1) + 'MB';
    }

    // 미리보기 이미지는 'ai-app-images'(공개 버킷)에 있어 로그인 없이도
    // 바로 표시할 수 있다(서명 없는 공개 URL).
    function imageUrl(path) {
      if (!path) return null;
      return sb.storage.from('ai-app-images').getPublicUrl(path).data.publicUrl;
    }

    function shotsHtml(a) {
      const shots = [
        [a.screenshot_app_path, '앱 화면'],
        [a.screenshot_result_path, '결과물 화면'],
      ].filter(([path]) => path);
      if (!shots.length) {
        return `<div class="app-badge">${esc(extBadge(a.file_name || a.storage_path))}</div>`;
      }
      return `<div class="app-shots">${shots
        .map(([path, label]) => {
          const url = esc(imageUrl(path));
          const alt = esc(`${a.title} ${label}`);
          return `<figure><img src="${url}" alt="${alt}" loading="lazy" class="app-shot-img" data-full="${url}" data-alt="${alt}" tabindex="0" role="button" aria-label="${alt} 크게 보기" /><figcaption>${label}</figcaption></figure>`;
        })
        .join('')}</div>`;
    }

    // 접근성: 열 때 닫기 버튼으로 포커스를 옮기고, 닫으면 열었던
    // 썸네일로 포커스를 되돌린다 (키보드 사용자 기준점 유지)
    let lightboxTrigger = null;
    function openLightbox(src, alt, trigger) {
      lightboxTrigger = trigger || null;
      $('lightbox-img').src = src;
      $('lightbox-img').alt = alt;
      $('lightbox').hidden = false;
      document.body.style.overflow = 'hidden';
      $('lightbox-close').focus();
    }

    function closeLightbox() {
      $('lightbox').hidden = true;
      $('lightbox-img').src = '';
      document.body.style.overflow = '';
      if (lightboxTrigger) {
        lightboxTrigger.focus();
        lightboxTrigger = null;
      }
    }

    $('lightbox-close').addEventListener('click', closeLightbox);
    // 이미지 바깥(어두운 배경)을 눌러도 닫힌다 — 이미지 자체를 누른 건 제외.
    $('lightbox').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !$('lightbox').hidden) closeLightbox();
    });

    // 목록(제목·이미지·설명)은 비회원도 볼 수 있다 — 실제 방어선은 다운로드
    // 요청 자체를 막는 storage.objects 권한(로그인+동의 완료 회원만)이라
    // 여기서는 canDownload로 버튼을 다운로드/회원가입 링크로 바꿔 보여준다.
    async function loadApps(canDownload) {
      const status = $('apps-status');
      const grid = $('apps-grid');
      const { data, error } = await sb
        .from('ai_apps')
        .select(
          'id, title, description, storage_path, file_name, file_size, screenshot_app_path, screenshot_result_path, created_at'
        )
        .eq('published', true)
        .order('created_at', { ascending: false });
      if (error) {
        status.textContent = '잠시 문제가 생겨 목록을 불러오지 못했습니다. 잠시 후 다시 시도해 주세요. 계속 안 되면 문의 페이지로 알려 주세요. (오류 내용: ' + error.message + ')';
        return;
      }
      if (!data.length) {
        status.textContent = '아직 등록된 항목이 없습니다.';
        return;
      }
      status.hidden = true;
      grid.innerHTML = data
        .map(
          (a) => `
        <article class="app-card" data-id="${a.id}">
          ${shotsHtml(a)}
          <p class="app-title">${esc(a.title)}</p>
          ${a.description ? `<p class="app-desc">${esc(a.description)}</p>` : ''}
          <p class="app-meta">${a.file_size ? esc(fmtBytes(a.file_size)) : ''}</p>
          ${
            canDownload
              ? `<button class="btn app-download" data-id="${a.id}">다운로드</button>`
              : `<a class="btn app-download" href="${esc(signupUrl)}">회원가입하고 다운로드</a>`
          }
        </article>`
        )
        .join('');

      // 스크린샷은 회원 여부와 무관하게 누구나 클릭해서 크게 볼 수 있다.
      grid.querySelectorAll('.app-shot-img').forEach((img) => {
        img.addEventListener('click', () => openLightbox(img.dataset.full, img.dataset.alt, img));
        img.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openLightbox(img.dataset.full, img.dataset.alt, img);
          }
        });
      });

      if (!canDownload) return; // 비회원 버튼은 회원가입 링크라 별도 로직이 필요 없다

      // 다운로드 버튼을 누를 때만 파일을 받는다(목록을 열 때 전부 미리
      // 받으면 배포 파일이 클 경우 방문 즉시 큰 트래픽이 발생하기 때문).
      grid.querySelectorAll('.app-download').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const app = data.find((x) => String(x.id) === btn.dataset.id);
          if (!app) return;
          const original = btn.textContent;
          btn.disabled = true;
          btn.textContent = '내려받는 중…';
          try {
            const { data: blob, error: dErr } = await sb.storage.from('ai-apps').download(app.storage_path);
            if (dErr) throw dErr;
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = app.file_name || app.storage_path;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
          } catch (e) {
            alert('잠시 문제가 생겨 다운로드하지 못했습니다. 잠시 후 다시 시도해 주세요. 계속 안 되면 문의 페이지로 알려 주세요. (오류 내용: ' + (e.message || e) + ')');
          } finally {
            btn.disabled = false;
            btn.textContent = original;
          }
        });
      });
    }

    const { data: { session } } = await sb.auth.getSession();
    let canDownload = false;
    if (session) {
      const { data: profile, error: pErr } = await sb
        .from('profiles')
        .select('id, consent_required_at')
        .eq('id', session.user.id)
        .maybeSingle();
      if (!pErr && profile && profile.consent_required_at) {
        canDownload = true;
        $('member-bar').hidden = false;
        const name = session.user.user_metadata?.name || session.user.email;
        $('member-name').textContent = `${name} 님`;
        $('logout').addEventListener('click', async () => {
          await sb.auth.signOut();
          location.reload();
        });
      } else {
        $('guest-banner').hidden = false;
        $('guest-banner').querySelector('.empty').textContent = pErr
          ? `잠시 문제가 생겨 회원 정보를 확인하지 못했습니다. 잠시 후 다시 시도해 주세요. 계속 안 되면 문의 페이지로 알려 주세요. (오류 내용: ${pErr.message})`
          : '이 계정에는 가입 동의 기록이 없어 다운로드할 수 없습니다. 로그아웃 후 다시 로그인하거나 운영자에게 문의해 주세요.';
      }
    } else {
      $('guest-banner').hidden = false;
    }
    loadApps(canDownload);
  })();
</script>

<style is:global>
  /* AI 앱 카드는 JS가 innerHTML로 런타임에 그려 넣는다. Astro의 스코프드
     CSS는 빌드 시점 템플릿 요소에만 붙는 data-astro-cid 속성으로 동작해
     런타임 삽입 요소에는 적용되지 않으므로(admin.astro와 동일 원인) 여기서도
     is:global을 쓴다. 페이지 고유 클래스명(app-*, apps-grid)만 써서 다른
     페이지와 충돌하지 않게 한다. */
  .member-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  /* 기본 스타일은 global.css의 .btn.ghost를 쓰고, 바(bar) 안에 맞게
     크기만 줄인다 */
  .member-bar .btn.ghost {
    padding: 0.4rem 1rem;
  }

  .empty,
  .hint {
    color: var(--color-muted);
  }

  .shots-disclaimer {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .app-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .app-badge {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 10px;
    background: var(--color-surface);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .app-shots {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .app-shots figure {
    margin: 0;
  }

  .app-shots img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
    background: var(--color-surface);
    display: block;
    cursor: zoom-in;
  }

  .app-shots figcaption {
    margin-top: 0.3rem;
    font-size: 0.72rem;
    color: var(--color-muted);
    text-align: center;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.85);
    cursor: zoom-out;
    padding: 2rem;
    box-sizing: border-box;
  }

  /* [hidden] 자체는 명시도가 .lightbox와 같아서(둘 다 0-1-0), 이 규칙이
     없으면 위 display:flex가 브라우저 기본 숨김 규칙을 이겨버려 닫아도
     검정 화면이 그대로 남는다. 명시도를 더 높여 확실히 이기게 한다. */
  .lightbox[hidden] {
    display: none;
  }

  .lightbox img {
    display: block;
    width: auto;
    height: auto;
    /* 이전 크기(썸네일의 약 4배, 568×426)에서 다시 3배 키운 값
       (1704×1278). 화면보다 커지지 않도록 뷰포트 상한도 함께 둔다.
       로딩 중에도 빈 화면처럼 보이지 않도록 최소 크기와 옅은 배경을
       준다(이미지 크기를 아직 몰라 사라져 보이던 문제 수정). */
    min-width: 120px;
    min-height: 90px;
    max-width: min(1704px, 92vw);
    max-height: min(1278px, 88vh);
    object-fit: contain;
    border-radius: 8px;
    cursor: default;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .app-title {
    font-weight: 600;
    font-size: 0.98rem;
  }

  .app-desc {
    font-size: 0.88rem;
    color: var(--color-muted);
    white-space: pre-wrap;
    flex: 1;
  }

  .app-meta {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .app-download {
    display: block;
    width: 100%;
    text-align: center;
    box-sizing: border-box;
  }

  .app-download:disabled {
    opacity: 0.5;
    cursor: default;
  }

  @media (max-width: 52rem) {
    .apps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 32rem) {
    .apps-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
