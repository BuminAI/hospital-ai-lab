---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/site';
import { guideHero, guideSteps, guideClosing } from '../data/guide';
---

<BaseLayout
  title="입문 가이드"
  description="책 대신 실전으로 AI를 익히는 다섯 단계. 유튜브 최신 영상 보기부터 따라 하기, 가르치기, 업무 적용, 전문가 교육까지 - 병원 행정·간호 종사자를 위한 입문 가이드입니다."
>
  <div class="container">
    <header class="page-head">
      <h1>{guideHero.h1}</h1>
      <p class="subtitle">{guideHero.subtitle}</p>
      <p class="lead">{guideHero.intro}</p>
    </header>

    <ol class="steps">
      {
        guideSteps.map((step) => (
          <li class="step">
            <h2>{step.title}</h2>
            <p class="step-lead"><strong>결론: {step.lead}</strong></p>
            <p>{step.body}</p>
            {step.links.length > 0 && (
              <ul class="step-links">
                {step.links.map((link) => (
                  <li>
                    {link.external ? (
                      <a href={link.href} target="_blank" rel="noopener">
                        {link.label}
                        <span class="sr-only"> (새 탭으로 열림)</span>
                      </a>
                    ) : (
                      <a href={withBase(link.href)}>{link.label} →</a>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ol>

    <p class="cycle-closing">{guideClosing}</p>

    <section class="see-also">
      <h2>더 볼 자료</h2>
      <div class="see-also-grid">
        <a class="see-also-card" href={withBase('/glossary/')}>
          <strong>의료 AI 용어 사전</strong>
          <span>제안서·회의에서 마주치는 용어를 주제별로 쉽게 풀었습니다.</span>
        </a>
        <a class="see-also-card" href={withBase('/faq/')}>
          <strong>자주 묻는 질문</strong>
          <span>입문자가 실제로 궁금해하는 질문에 답합니다.</span>
        </a>
        <a class="see-also-card" href={withBase('/checklist/')}>
          <strong>AI 도입 검토 체크리스트</strong>
          <span>도입 제안을 검토할 때 확인할 항목을 정리했습니다.</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .subtitle {
    margin-top: 0.5rem;
    max-width: var(--prose-width);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .steps {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    max-width: var(--prose-width);
    counter-reset: step;
  }

  .step {
    position: relative;
    padding: 0 0 2.25rem 1.9rem;
    border-left: 2px solid var(--color-border);
  }

  .step:last-child {
    padding-bottom: 0.25rem;
  }

  .step::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 0.4em;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .step h2 {
    font-size: 1.15rem;
  }

  .step p {
    margin-top: 0.6rem;
    color: var(--color-muted);
  }

  .step-lead strong {
    color: var(--color-text);
  }

  .cycle-closing {
    margin: 2.5rem 0 0;
    max-width: var(--prose-width);
    padding: 1.5rem 1.75rem;
    background: var(--color-primary-soft);
    border-radius: var(--radius);
    color: var(--color-text);
  }

  .step-links {
    list-style: none;
    margin: 0.85rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .step-links a {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .see-also {
    margin-top: 1rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .see-also h2 {
    font-size: 1.25rem;
  }

  .see-also-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .see-also-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    color: var(--color-text);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .see-also-card:hover {
    text-decoration: none;
    border-color: var(--color-primary);
    box-shadow: 0 4px 14px rgba(11, 83, 148, 0.08);
    transform: translateY(-2px);
  }

  .see-also-card strong {
    display: block;
    font-size: 1.05rem;
  }

  .see-also-card span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  @media (max-width: 52rem) {
    .see-also-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
