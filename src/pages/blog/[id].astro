---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase, formatDate, SITE_TITLE } from '../../utils/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// BlogPosting 구조화 데이터. 저자는 개인 창작 정보 없이 발행 주체(연구소)로 표기.
const canonicalUrl = Astro.site
  ? new URL(withBase(`/blog/${post.id}/`), Astro.site).href
  : withBase(`/blog/${post.id}/`);
// 대표 이미지는 사이트 공통 OG 이미지(절대 URL 필요 — BaseLayout과 동일 규칙)
const ogImageUrl = Astro.site
  ? new URL(withBase('/og-default.png'), Astro.site).href
  : withBase('/og-default.png');
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  // 별도 수정일 필드를 두지 않으므로 발행일과 동일하게 표기
  dateModified: post.data.pubDate.toISOString(),
  articleSection: post.data.category,
  image: ogImageUrl,
  mainEntityOfPage: canonicalUrl,
  author: { '@type': 'Organization', name: SITE_TITLE },
  publisher: { '@type': 'Organization', name: SITE_TITLE },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  pubDate={post.data.pubDate}
  category={post.data.category}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <div class="container">
    <article>
      <header class="post-head">
        <div class="meta">
          <span class="chip">{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
        </div>
        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer class="post-foot">
        <a href={withBase('/blog/')}>← 블로그 목록으로</a>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .post-head {
    padding-block: 3.5rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
    max-width: var(--prose-width);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .post-head h1 {
    margin-top: 1.25rem;
    font-size: clamp(1.6rem, 4vw, 2.1rem);
  }

  .description {
    margin-top: 1rem;
    color: var(--color-muted);
  }

  .post-foot {
    max-width: var(--prose-width);
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .post-foot a {
    font-weight: 600;
  }
</style>
