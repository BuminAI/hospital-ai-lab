---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchIcon from '../components/ResearchIcon.astro';
import { researchAreas } from '../data/research';
---

<BaseLayout
  title="연구"
  description="병원 운영 데이터, 의료 자원 배분, 통계적 타당성, 병원 기획자를 위한 AI — 병원 AI 연구소의 연구 분야를 소개합니다."
>
  <div class="container">
    <header class="page-head">
      <h1>연구 분야</h1>
      <p class="lead">
        통계적으로 타당하고, 경제적으로 합리적이며, 현장에서 실행 가능한 AI
        활용법을 연구합니다.
      </p>
    </header>

    <div class="areas">
      {
        researchAreas.map((area) => (
          <article class="area">
            <ResearchIcon icon={area.icon} />
            <div>
              <h2>{area.title}</h2>
              <p>{area.full}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .areas {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .area {
    display: flex;
    gap: 1.75rem;
    padding-block: 2.25rem;
    border-top: 1px solid var(--color-border);
  }

  .area:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .area h2 {
    font-size: 1.25rem;
  }

  .area p {
    margin-top: 0.75rem;
    max-width: var(--prose-width);
    color: var(--color-muted);
  }

  @media (max-width: 40rem) {
    .area {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
