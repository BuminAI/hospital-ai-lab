---
import BaseLayout from '../layouts/BaseLayout.astro';
import allVideos from '../data/recommended-videos.json';

const CHANNEL_URL = 'https://www.youtube.com/@HospitalAILAB';
const VISIBLE_LIMIT = 6;

// 다른 채널 추천 영상은 최신 업데이트순(내림차순)으로 정렬한다.
const videos = allVideos
  .filter((v) => v.source !== 'own')
  .sort((a, b) => new Date(b.addedAt) - new Date(a.addedAt));

// 연구소장 영상은 1강→2강→3강 순서(등록 순, addedAt 오름차순)를 그대로
// 유지한다 — 강의 시리즈라 "최신순"으로 뒤집으면 순서가 깨진다. 두
// 섹션 모두 6개까지만 보이고 나머지는 소제목을 눌러야 펼쳐진다.
const ownVideos = allVideos
  .filter((v) => v.source === 'own')
  .sort((a, b) => new Date(a.addedAt) - new Date(b.addedAt));
---

<BaseLayout
  title="추천 영상"
  description="병원 AI 연구소가 병원 행정·간호 실무자에게 참고할 만한 AI 입문 영상을 추천합니다."
>
  <div class="container">
    <header class="page-head">
      <h1>추천 영상</h1>
      <p class="lead">
        병원 행정·간호 실무자에게 도움이 될 AI 입문 강의 영상을 매주 월·수·금
        3개씩 새로 찾아 모읍니다.
      </p>
      <p class="notice">
        최근 3개월 이내에 올라온 클로드(Claude)·병원·의료 AI 입문 영상 중 많이
        본 한국어 영상을 골라 싣습니다. 목록의 영상은 각 채널 제작자가 만든
        것입니다. 여기 실린 것은 연구소가 골랐다는 뜻일 뿐, 제휴나 후원 관계는
        없습니다.
      </p>
    </header>

    <section>
      <h2 class="section-label">
        {
          ownVideos.length > VISIBLE_LIMIT ? (
            <button type="button" class="section-toggle" aria-expanded="false" aria-controls="own-grid">
              연구소장이 직접 만든 영상
              <span class="toggle-text">더보기 ({ownVideos.length - VISIBLE_LIMIT}) ▾</span>
            </button>
          ) : (
            '연구소장이 직접 만든 영상'
          )
        }
      </h2>
      {
        ownVideos.length > 0 ? (
          <div class="video-grid" id="own-grid">
            {ownVideos.map((v, i) => (
              <a
                class="video-card"
                href={v.url}
                target="_blank"
                rel="noopener"
                data-extra={i >= VISIBLE_LIMIT ? 'true' : undefined}
                hidden={i >= VISIBLE_LIMIT}
              >
                <img
                  src={`https://img.youtube.com/vi/${v.videoId}/hqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  width="480"
                  height="360"
                />
                <p class="video-title">
                  {v.title}
                  <span class="sr-only"> (유튜브, 새 탭으로 열림)</span>
                </p>
              </a>
            ))}
          </div>
        ) : (
          <div class="channel-card">
            <span class="chip">준비 중</span>
            <p>
              아직 영상 제작 전입니다. 채널을 미리 구독해 두시면 첫 영상이
              올라올 때 바로 확인하실 수 있습니다.
            </p>
            <a class="btn" href={CHANNEL_URL} target="_blank" rel="noopener">
              유튜브 채널 바로가기
            </a>
          </div>
        )
      }
    </section>

    <section class="channel-section">
      <h2 class="section-label">
        {
          videos.length > VISIBLE_LIMIT ? (
            <button type="button" class="section-toggle" aria-expanded="false" aria-controls="others-grid">
              다른 채널의 추천 영상
              <span class="toggle-text">더보기 ({videos.length - VISIBLE_LIMIT}) ▾</span>
            </button>
          ) : (
            '다른 채널의 추천 영상'
          )
        }
      </h2>
      {
        videos.length > 0 ? (
          <div class="video-grid" id="others-grid">
            {videos.map((v, i) => (
              <a
                class="video-card"
                href={v.url}
                target="_blank"
                rel="noopener"
                data-extra={i >= VISIBLE_LIMIT ? 'true' : undefined}
                hidden={i >= VISIBLE_LIMIT}
              >
                <img
                  src={`https://img.youtube.com/vi/${v.videoId}/hqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  width="480"
                  height="360"
                />
                <p class="video-title">
                  {v.title}
                  <span class="sr-only"> (유튜브, 새 탭으로 열림)</span>
                </p>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty">아직 추천 영상이 없습니다.</p>
        )
      }
    </section>
  </div>
</BaseLayout>

<script>
  // 소제목(section-toggle 버튼)을 누르면 6개 뒤로 숨겨 둔 영상(data-extra)을
  // 펼치거나 다시 접는다. 서버가 그린 요소를 그대로 쓰므로 스코프드 스타일이
  // 정상 적용된다(admin·홈처럼 innerHTML로 새로 그리는 페이지가 아님).
  document.querySelectorAll('.section-toggle').forEach((btn) => {
    const gridId = btn.getAttribute('aria-controls');
    const grid = gridId ? document.getElementById(gridId) : null;
    const extraCards = grid ? grid.querySelectorAll('.video-card[data-extra]') : [];
    const label = btn.querySelector('.toggle-text');
    btn.addEventListener('click', () => {
      const expanding = btn.getAttribute('aria-expanded') !== 'true';
      btn.setAttribute('aria-expanded', String(expanding));
      extraCards.forEach((card) => {
        card.hidden = !expanding;
      });
      if (label) label.textContent = expanding ? '접기 ▴' : `더보기 (${extraCards.length}) ▾`;
    });
  });
</script>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .video-card {
    display: block;
    color: var(--color-text);
  }

  .video-card:hover {
    text-decoration: none;
  }

  .video-card:hover .video-title {
    color: var(--color-primary);
  }

  .video-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .video-title {
    margin-top: 0.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .empty {
    margin-top: 1.5rem;
    color: var(--color-muted);
  }

  .section-label {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--color-muted);
  }

  .section-toggle {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .section-toggle:hover {
    color: var(--color-primary);
  }

  .toggle-text {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
  }

  /* 선정 기준·면책 안내 — lead보다 한 단계 낮은 톤 */
  .notice {
    margin-top: 0.9rem;
    max-width: var(--prose-width);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  header + section {
    margin-top: 1.5rem;
  }

  .channel-section {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .channel-card {
    margin-top: 1rem;
    max-width: var(--prose-width);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }

  .channel-card p {
    margin-top: 0.5rem;
    color: var(--color-muted);
  }

  .channel-card .btn {
    margin-top: 1.25rem;
  }

  @media (max-width: 52rem) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 32rem) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
