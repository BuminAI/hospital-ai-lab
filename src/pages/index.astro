---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ResearchIcon from '../components/ResearchIcon.astro';
import { researchAreas } from '../data/research';
import { withBase, SITE_TAGLINE, SITE_TITLE } from '../utils/site';
import news from '../data/news.json';
import videos from '../data/recommended-videos.json';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// 관리자가 특정 글을 "대표글"로 지정하면 그 글을, 아니면 가장 최근 글을 히어로에 노출
const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const recentPosts = allPosts.filter((p) => p.id !== featured?.id).slice(0, 3);

const homeAreas = researchAreas.slice(0, 3);
const recentNews = news.items.slice(0, 5);
// 연구소장이 직접 만든 영상은 별도 코너(/youtube/)에서만 보여주고,
// 홈의 "추천 강의 영상"에는 다른 채널 영상만 노출한다
const homeVideos = videos.filter((v) => v.source !== 'own').slice(0, 3);

// 홈에만 넣는 구조화 데이터 (site.ts 확정값만 사용, 창작 정보 없음)
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://hospital-ai-lab.com';
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_TITLE,
  url: siteUrl,
  logo: `${siteUrl}${withBase('/og-default.png')}`,
};
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  url: siteUrl,
};
---

<BaseLayout description={SITE_TAGLINE}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(orgJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd)} />

  <!-- 히어로: 브랜드 소개 + 가장 최근 글을 전면에 -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-intro">
        <p class="eyebrow">HOSPITAL AI LAB</p>
        <h1>의료 현장의 문제를<br />AI로 풉니다.</h1>
        <p class="tagline">
          17년간 병원 현장에서 쌓은 경험을 AI 활용과 연결합니다. 화려한 기술
          소개보다 "실제로 병원에서 쓸 수 있는가"를 먼저 묻습니다.
        </p>
        <a class="btn" href={withBase('/about/')}>연구소 소개 보기</a>
      </div>

      {
        featured && (
          <a class="hero-featured" href={withBase(`/blog/${featured.id}/`)}>
            <div class="hf-meta">
              <span class="chip">{featured.data.category}</span>
              <span class="hf-label">가장 최근 글</span>
            </div>
            <h2 class="hf-title">{featured.data.title}</h2>
            <p class="hf-desc">{featured.data.description}</p>
            <span class="hf-more">이어 읽기 →</span>
          </a>
        )
      }
    </div>
  </section>

  <!-- 구독 안내 배너 (전면 배치) -->
  <section class="section">
    <div class="container">
      <div class="subscribe-band">
        <div>
          <h2>새 글과 AI 뉴스를 놓치지 마세요</h2>
          <p>
            매일 아침 자동으로 모으는 의료 AI 뉴스와 새 칼럼을 받아보세요.
            회원가입하면 병원 행정·간호 실무자를 위한 강의노트까지 볼 수 있습니다.
          </p>
        </div>
        <div class="band-actions">
          <a class="btn" href={withBase('/signup/')}>회원가입</a>
          <a class="btn ghost" href={withBase('/rss.xml')}>RSS 구독</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 최근 글 -->
  {
    recentPosts.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>최근 글</h2>
            <a class="more" href={withBase('/blog/')}>블로그 전체 보기 →</a>
          </div>
          <div class="grid-3">
            {recentPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- 최근 AI 뉴스 -->
  {
    recentNews.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>최근 AI 뉴스</h2>
            <a class="more" href={withBase('/news/')}>AI 뉴스 전체 보기 →</a>
          </div>
          <ul class="news-preview">
            {recentNews.map((item) => (
              <li>
                <a href={item.link} target="_blank" rel="noopener">
                  {item.title}
                  <span class="sr-only"> (새 탭으로 열림)</span>
                </a>
                {item.source && <span class="src">{item.source}</span>}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- 추천 강의 영상 -->
  {
    homeVideos.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>추천 강의 영상</h2>
            <a class="more" href={withBase('/youtube/')}>추천 영상 전체 보기 →</a>
          </div>
          <div class="grid-3">
            {homeVideos.map((v) => (
              <a class="video-card" href={v.url} target="_blank" rel="noopener">
                <img
                  src={`https://img.youtube.com/vi/${v.videoId}/hqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  width="480"
                  height="360"
                />
                <p class="video-title">
                  {v.title}
                  <span class="sr-only"> (유튜브, 새 탭으로 열림)</span>
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- 연구 분야 (소개 성격이라 콘텐츠 아래에 배치) -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>연구 분야</h2>
        <a class="more" href={withBase('/about/#research')}>전체 연구 분야 보기 →</a>
      </div>
      <div class="grid-3">
        {
          homeAreas.map((area) => (
            <article class="card">
              <ResearchIcon icon={area.icon} />
              <h3>{area.title}</h3>
              <p>{area.short}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 입문 가이드 안내 -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>AI 입문, 여기서 시작하세요</h2>
        <a class="more" href={withBase('/guide/')}>입문 가이드 전체 보기 →</a>
      </div>
      <div class="grid-3">
        <a class="card guide-card" href={withBase('/guide/')}>
          <h3>입문 가이드</h3>
          <p>무엇을, 어떤 순서로 공부하면 되는지 6단계로 안내합니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/glossary/')}>
          <h3>의료 AI 용어 사전</h3>
          <p>제안서·회의에서 마주치는 용어를 항목별로 정리했습니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/faq/')}>
          <h3>자주 묻는 질문</h3>
          <p>입문자가 실제로 궁금해하는 질문에 답합니다.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 문의 배너 -->
  <section class="section">
    <div class="container">
      <div class="contact-banner">
        <div>
          <h2>함께 고민하고 싶은 문제가 있으신가요?</h2>
          <p>연구 주제 제안, 협업, 콘텐츠에 대한 문의를 기다립니다.</p>
        </div>
        <a class="btn" href={withBase('/contact/')}>문의하기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── 히어로 ── */
  .hero {
    padding-block: 4rem 3.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.75rem;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .hero h1 {
    margin-top: 0.75rem;
    font-size: clamp(1.9rem, 4.6vw, 2.8rem);
  }

  .hero .tagline {
    margin-top: 1.25rem;
    max-width: 34rem;
    font-size: 1.075rem;
    color: var(--color-muted);
  }

  .hero .btn {
    margin-top: 1.75rem;
  }

  /* 히어로 안의 최근 글 카드 */
  .hero-featured {
    display: block;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .hero-featured:hover {
    text-decoration: none;
    border-color: var(--color-primary);
    box-shadow: 0 6px 20px rgba(11, 83, 148, 0.08);
    transform: translateY(-2px);
  }

  .hf-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hf-label {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .hf-title {
    margin-top: 0.85rem;
    font-size: 1.4rem;
    line-height: 1.4;
  }

  .hf-desc {
    margin-top: 0.75rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hf-more {
    display: inline-block;
    margin-top: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── 섹션 공통 ── */
  .section {
    padding-block: 3.25rem 1rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-bottom: 1.75rem;
  }

  .section-head h2 {
    position: relative;
    padding-left: 0.85rem;
    font-size: 1.5rem;
  }

  /* 캐릿식 섹션 제목 강조 — 왼쪽 세로 악센트 바 */
  .section-head h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.18em;
    bottom: 0.18em;
    width: 4px;
    border-radius: 2px;
    background: var(--color-primary);
  }

  .more {
    font-size: 0.925rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .card h3 {
    margin-top: 1.1rem;
    font-size: 1.125rem;
  }

  .card p {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  /* 입문 가이드 안내 카드 (링크이므로 밑줄·색 규칙을 별도로 지정) */
  .guide-card {
    display: block;
    color: var(--color-text);
  }

  .guide-card:hover {
    text-decoration: none;
  }

  .guide-card:hover h3 {
    color: var(--color-primary);
  }

  /* 추천 영상 카드 */
  .video-card {
    display: block;
    color: var(--color-text);
  }

  .video-card:hover {
    text-decoration: none;
  }

  .video-card:hover .video-title {
    color: var(--color-primary);
  }

  .video-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .video-title {
    margin-top: 0.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
  }

  /* AI 뉴스 미리보기 */
  .news-preview {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 52rem;
  }

  .news-preview li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .news-preview li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .news-preview a {
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.5;
  }

  .news-preview a:hover {
    color: var(--color-primary);
  }

  .news-preview .src {
    flex-shrink: 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  /* ── 배너 (구독·문의) ── */
  .subscribe-band,
  .contact-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    background: var(--color-primary-soft);
    border-radius: var(--radius);
    padding: 2.25rem 2.25rem;
  }

  .subscribe-band h2,
  .contact-banner h2 {
    font-size: 1.35rem;
  }

  .subscribe-band p,
  .contact-banner p {
    margin-top: 0.5rem;
    color: var(--color-muted);
    max-width: 40rem;
  }

  .band-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn.ghost {
    background: var(--color-bg);
    color: var(--color-primary);
    border: 1px solid var(--color-border);
  }

  .btn.ghost:hover {
    border-color: var(--color-primary);
  }

  @media (max-width: 52rem) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .grid-3 {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-block: 3rem 2.75rem;
    }
  }
</style>
