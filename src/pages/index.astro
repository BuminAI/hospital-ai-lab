---
import { execSync } from 'node:child_process';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchIcon from '../components/ResearchIcon.astro';
import { researchAreas } from '../data/research';
import {
  withBase,
  formatDate,
  SITE_TITLE,
  SUPABASE_URL,
  SUPABASE_ANON_KEY,
} from '../utils/site';
import news from '../data/news.json';
import videos from '../data/recommended-videos.json';

// 마지막 업데이트일 = 마지막 커밋 날짜(빌드 시 자동 계산, 수동 갱신 불필요).
// git 정보를 못 구하는 예외적 빌드 환경 대비 폴백만 둔다.
let lastUpdated = '';
try {
  lastUpdated = execSync('git log -1 --format=%cd --date=format:%Y-%m-%d').toString().trim();
} catch {
  lastUpdated = new Date().toISOString().slice(0, 10);
}

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// 히어로의 "최근 소식" 미니 피드(최신 4건) + 아래쪽 "이어지는 소식"
// 게시판(5번째 이후)이 공유하는 시드 데이터. JS가 실패해도 게시판이
// 비지 않도록 넉넉히 10건까지 시드한다. 강의노트·AI 앱은 클라이언트에서
// 불러와 이 배열에 합쳐진다(아래 스크립트).
const blogFeedSeed = allPosts.slice(0, 10).map((post) => ({
  badgeClass: 'feed-badge-blog',
  badgeLabel: '칼럼',
  title: post.data.title,
  dateIso: post.data.pubDate.toISOString(),
  href: withBase(`/blog/${post.id}/`),
}));

const homeAreas = researchAreas.slice(0, 3);
const recentNews = news.items.slice(0, 5);
// 홈의 "추천 강의 영상"에는 연구소장이 직접 만든 영상 1편 + 다른 채널
// 영상 2편을 섞어 보여준다("직접 만든 영상"이 이 사이트의 실적 증거).
const homeVideos = [
  ...videos.filter((v) => v.source === 'own').slice(0, 1),
  ...videos.filter((v) => v.source !== 'own').slice(0, 2),
];

// 신뢰 스탯 스트립 수치 — 전부 빌드 시 실측치(수동 갱신·창작 없음).
const contentCount = allPosts.length + videos.length;

// 홈 전용 설명문 (briefing.md 사실 범위: 경력·대상 독자·콘텐츠 종류만)
const homeDescription =
  '종합병원에서 17년 일한 실무자가 병원 행정·간호의 언어로 의료 AI를 공부하고 기록합니다. 매일 자동으로 모으는 의료 AI 뉴스와 칼럼, 강의노트, 추천 영상을 담았습니다.';

// 홈에만 넣는 구조화 데이터 (site.ts 확정값만 사용, 창작 정보 없음)
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://hospital-ai-lab.com';
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_TITLE,
  url: siteUrl,
  logo: `${siteUrl}${withBase('/og-default.png')}`,
};
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  url: siteUrl,
};
---

<BaseLayout description={homeDescription}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(orgJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd)} />

  <!-- 히어로: 브랜드 소개 + 가장 최근 글을 전면에 -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-intro">
        <p class="eyebrow">HOSPITAL AI LAB</p>
        <h1>병원 17년차 실무자가<br />행정·간호의 언어로 AI를 공부하고 기록합니다.</h1>
        <p class="tagline">
          17년간 병원 현장에서 쌓은 경험을 AI 활용과 연결합니다. 화려한 기술
          소개보다 "실제로 병원에서 쓸 수 있는가"를 먼저 묻습니다.
        </p>
        <div class="hero-actions">
          <a class="btn" href={withBase('/guide/')}>AI 입문 가이드 시작하기</a>
          <a class="btn ghost" href={withBase('/about/')}>연구소 소개</a>
        </div>
      </div>

      <div class="hero-feed-card">
        <div class="hero-feed-head">
          <span class="live-dot" aria-hidden="true"></span>
          최근 올라온 소식
        </div>
        <ul class="hero-feed" id="hero-feed">
          {blogFeedSeed.slice(0, 4).map((item) => (
            <li class="feed-row" data-date={item.dateIso}>
              <span class={`feed-badge ${item.badgeClass}`}>{item.badgeLabel}</span>
              <a class="feed-title" href={item.href}>{item.title}</a>
              <time class="feed-date" datetime={item.dateIso}>{formatDate(new Date(item.dateIso))}</time>
            </li>
          ))}
        </ul>
        <a class="hero-feed-more" href="#activity-feed">이어지는 소식 보기 ↓</a>
      </div>
    </div>
  </section>

  <!-- 신뢰 스탯 스트립: 전부 briefing.md 사실 + 빌드 시 실측치 -->
  <section class="stat-strip" aria-label="연구소 활동 현황">
    <div class="container">
      <ul>
        <li><strong>종합병원 근무 17년</strong> (기획 7년)</li>
        <li>매일 자동 수집한 의료 AI 뉴스 <strong>{news.items.length}건</strong></li>
        <li>글·추천 영상 <strong>{contentCount}건</strong></li>
        <li>마지막 업데이트 {lastUpdated}</li>
      </ul>
    </div>
  </section>

  <!-- 입문 가이드 안내: 첫 방문자용 콘텐츠라 최상단에 배치 -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>AI 입문, 여기서 시작하세요</h2>
        <a class="more" href={withBase('/guide/')}>입문 가이드 전체 보기 →</a>
      </div>
      <div class="grid-3">
        <a class="card guide-card" href={withBase('/checklist/')}>
          <h3>AI 도입 검토 체크리스트</h3>
          <p>도입 제안을 검토할 때 확인할 항목을 정리했습니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/glossary/')}>
          <h3>의료 AI 용어 사전</h3>
          <p>제안서·회의에서 마주치는 용어를 주제별로 쉽게 풀었습니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/faq/')}>
          <h3>자주 묻는 질문</h3>
          <p>입문자가 실제로 궁금해하는 질문에 답합니다.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 이어지는 소식: 칼럼·강의노트·AI로 만든 앱을 한 게시판에 모은다.
       히어로 미니 피드가 최신 4건을 보여주므로 여기는 5번째 이후를 이어서
       보여준다(두 목록이 겹치지 않게). 블로그는 빌드 시점에 바로 나오고
       (무JS에서도 보임), 강의노트·AI 앱은 페이지가 뜬 뒤 자바스크립트가
       불러와 같은 목록에 합쳐 넣는다. -->
  {
    blogFeedSeed.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>이어지는 소식</h2>
          </div>
          <p class="feed-note">
            칼럼·강의노트·AI로 만든 앱 — 새로 올라온 순서대로 모았습니다.
          </p>
          <ul class="activity-feed" id="activity-feed">
            {blogFeedSeed.slice(4, 10).map((item) => (
              <li class="feed-row" data-date={item.dateIso}>
                <span class={`feed-badge ${item.badgeClass}`}>{item.badgeLabel}</span>
                <a class="feed-title" href={item.href}>
                  {item.title}
                </a>
                <time class="feed-date" datetime={item.dateIso}>{formatDate(new Date(item.dateIso))}</time>
              </li>
            ))}
          </ul>
          <div class="feed-links">
            <a class="more" href={withBase('/blog/')}>블로그 전체 보기 →</a>
            <a class="more" href={withBase('/notes/')}>강의노트 보기 →</a>
            <a class="more" href={withBase('/ai-apps/')}>AI로 만든 앱 보기 →</a>
          </div>
        </div>
      </section>
    )
  }

  <!-- 최근 AI 뉴스 -->
  {
    recentNews.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>최근 AI 뉴스</h2>
            <a class="more" href={withBase('/news/')}>AI 뉴스 전체 보기 →</a>
          </div>
          <ul class="news-preview">
            {recentNews.map((item) => (
              <li>
                <a href={item.link} target="_blank" rel="noopener">
                  {item.title}
                  <span class="sr-only"> (새 탭으로 열림)</span>
                </a>
                {item.source && <span class="src">{item.source}</span>}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- 추천 강의 영상 -->
  {
    homeVideos.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>추천 강의 영상</h2>
            <a class="more" href={withBase('/youtube/')}>추천 영상 전체 보기 →</a>
          </div>
          <div class="grid-3">
            {homeVideos.map((v) => (
              <a class="video-card" href={v.url} target="_blank" rel="noopener">
                <img
                  src={`https://img.youtube.com/vi/${v.videoId}/hqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  width="480"
                  height="360"
                />
                <p class="video-title">
                  {v.title}
                  <span class="sr-only"> (유튜브, 새 탭으로 열림)</span>
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- 연구 분야 (소개 성격이라 콘텐츠 아래에 배치) -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>연구 분야</h2>
        <a class="more" href={withBase('/about/#research')}>전체 연구 분야 보기 →</a>
      </div>
      <div class="grid-3">
        {
          homeAreas.map((area) => (
            <article class="card">
              <ResearchIcon icon={area.icon} />
              <h3>{area.title}</h3>
              <p>{area.short}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 통합 밴드: 구독 + 문의 (가치를 보여준 뒤 하단에서 한 번만 요청) -->
  <section class="section">
    <div class="container">
      <div class="subscribe-band">
        <div>
          <h2>새 글과 AI 뉴스를 놓치지 마세요</h2>
          <p>
            매일 자동으로 모으는 의료 AI 뉴스와 새 칼럼을 받아보세요.
            회원가입하면 병원 행정·간호 실무자를 위한 강의노트까지 볼 수 있습니다.
          </p>
        </div>
        <div class="band-actions">
          <a class="btn" href={withBase('/signup/')}>회원가입</a>
          <a class="btn ghost" href={withBase('/rss.xml')}>새 글 자동 받기(RSS)</a>
          <a class="btn ghost" href={withBase('/contact/')}>문의하기</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 사이트 갱신 상태 표시: 날짜는 마지막 커밋에서 자동 계산된다. -->
  <p class="dev-status">
    이 홈페이지는 계속 업데이트되고 있습니다 · 마지막 업데이트 {lastUpdated}
  </p>
</BaseLayout>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY, blogFeedSeed }}>
  // 히어로의 "최근 소식" 미니 피드와, 아래쪽 "이어지는 소식" 전체
  // 게시판을 같은 데이터에서 함께 채운다. 블로그는 빌드 시점에 이미
  // 받은 값(blogFeedSeed)이고, 강의노트·AI로 만든 앱만 여기서 불러와
  // 합친 뒤 날짜순으로 정렬해 두 곳에 나눠 그린다.
  (async () => {
    const heroFeed = document.getElementById('hero-feed');
    const mainFeed = document.getElementById('activity-feed');
    if (!mainFeed) return;

    const fmt = (iso) =>
      new Date(iso).toLocaleDateString('ko-KR', {
        timeZone: 'Asia/Seoul',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

    function makeRow({ badgeClass, badgeLabel, title, dateIso, href }) {
      const li = document.createElement('li');
      li.className = 'feed-row';
      li.dataset.date = dateIso;

      const badge = document.createElement('span');
      badge.className = `feed-badge ${badgeClass}`;
      badge.textContent = badgeLabel;

      const titleEl = document.createElement('a');
      titleEl.className = 'feed-title';
      titleEl.href = href;
      titleEl.textContent = title;

      const dateEl = document.createElement('time');
      dateEl.className = 'feed-date';
      dateEl.dateTime = dateIso;
      dateEl.textContent = fmt(dateIso);

      li.append(badge, titleEl, dateEl);
      return li;
    }

    function render(container, rows) {
      if (!container) return;
      container.innerHTML = '';
      rows.forEach((r) => container.appendChild(makeRow(r)));
    }

    const items = [...blogFeedSeed];

    if (SUPABASE_URL) {
      try {
        // 단순 SELECT 두 번이라 supabase-js 클라이언트 전체를 내려받지
        // 않고 REST API로 바로 조회한다(외부 스크립트 의존 제거).
        const headers = { apikey: SUPABASE_ANON_KEY };
        const query = 'select=id,title,created_at&published=eq.true&order=created_at.desc&limit=3';
        const [notesRes, appsRes] = await Promise.all([
          fetch(`${SUPABASE_URL}/rest/v1/lecture_notes?${query}`, { headers }),
          fetch(`${SUPABASE_URL}/rest/v1/ai_apps?${query}`, { headers }),
        ]);
        const notes = notesRes.ok ? await notesRes.json() : [];
        const apps = appsRes.ok ? await appsRes.json() : [];
        const notesUrl = new URL('notes/', location.href).pathname;
        const appsUrl = new URL('ai-apps/', location.href).pathname;

        (notes || []).forEach((n) =>
          items.push({
            badgeClass: 'feed-badge-note',
            badgeLabel: '강의노트',
            title: n.title,
            dateIso: n.created_at,
            href: notesUrl,
          })
        );
        (apps || []).forEach((a) =>
          items.push({
            badgeClass: 'feed-badge-app',
            badgeLabel: 'AI로 만든 앱',
            title: a.title,
            dateIso: a.created_at,
            href: appsUrl,
          })
        );
      } catch {
        // 강의노트·AI 앱을 못 불러와도 블로그 목록은 그대로 보이니
        // 조용히 넘어간다(레이아웃이 깨지지 않게).
      }
    }

    items.sort((a, b) => new Date(b.dateIso) - new Date(a.dateIso));

    // 히어로 미니 피드: 최신 4개. 아래 게시판: 5번째부터 이어서
    // (두 목록이 같은 항목을 두 번 보여주지 않게).
    render(heroFeed, items.slice(0, 4));
    render(mainFeed, items.slice(4, 10));
  })();
</script>

<style>
  /* ── 히어로 ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: 4.5rem 4rem;
    border-bottom: 1px solid var(--color-border);
    background:
      radial-gradient(56rem 28rem at 88% -12%, var(--hero-glow), transparent 62%),
      linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 90%);
  }

  /* 오른쪽으로만 스며드는 도트 그리드 — '데이터' 뉘앙스를 절제해 표현 */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--hero-dot) 1px, transparent 1.5px);
    background-size: 22px 22px;
    -webkit-mask-image: linear-gradient(115deg, transparent 45%, rgba(0, 0, 0, 0.9) 100%);
    mask-image: linear-gradient(115deg, transparent 45%, rgba(0, 0, 0, 0.9) 100%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.75rem;
    align-items: center;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
  }

  .hero h1 {
    margin-top: 0.75rem;
    font-size: clamp(1.9rem, 4.6vw, 2.8rem);
  }

  .hero .tagline {
    margin-top: 1.25rem;
    max-width: 34rem;
    font-size: 1.075rem;
    color: var(--color-muted);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  /* 히어로 안의 "최근 소식" 미니 피드 카드 — 사이트가 계속 갱신되고
     있음을 방문 즉시 보여준다(맨 위 칼럼·강의노트·AI 앱을 뒤섞은 목록). */
  .hero-feed-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 1.5rem 1.6rem;
  }

  .hero-feed-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-live);
    box-shadow: 0 0 0 0 var(--color-live-pulse);
    animation: live-pulse 2s infinite;
  }

  @keyframes live-pulse {
    0% {
      box-shadow: 0 0 0 0 var(--color-live-pulse);
    }
    70% {
      box-shadow: 0 0 0 7px transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-dot {
      animation: none;
    }
  }

  .hero-feed {
    margin-top: 0.9rem;
  }

  .hero-feed-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── 신뢰 스탯 스트립 ── */
  .stat-strip {
    border-bottom: 1px solid var(--color-border);
  }

  .stat-strip ul {
    list-style: none;
    margin: 0;
    padding: 0.9rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }

  .stat-strip li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    white-space: nowrap;
  }

  .stat-strip li + li::before {
    content: '·';
