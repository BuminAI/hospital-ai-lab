---
import { execSync } from 'node:child_process';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchIcon from '../components/ResearchIcon.astro';
import { researchAreas } from '../data/research';
import {
  withBase,
  formatDate,
  SITE_TAGLINE,
  SITE_TITLE,
  SITE_VERSION,
  SUPABASE_URL,
  SUPABASE_ANON_KEY,
} from '../utils/site';
import news from '../data/news.json';
import videos from '../data/recommended-videos.json';

// 마지막 업데이트일 = 마지막 커밋 날짜(빌드 시 자동 계산, 수동 갱신 불필요).
// git 정보를 못 구하는 예외적 빌드 환경 대비 폴백만 둔다.
let lastUpdated = '';
try {
  lastUpdated = execSync('git log -1 --format=%cd --date=format:%Y-%m-%d').toString().trim();
} catch {
  lastUpdated = new Date().toISOString().slice(0, 10);
}

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// 관리자가 특정 글을 "대표글"로 지정하면 그 글을, 아니면 가장 최근 글을 히어로에 노출
const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const recentPosts = allPosts.filter((p) => p.id !== featured?.id).slice(0, 3);

const homeAreas = researchAreas.slice(0, 3);
const recentNews = news.items.slice(0, 5);
// 연구소장이 직접 만든 영상은 별도 코너(/youtube/)에서만 보여주고,
// 홈의 "추천 강의 영상"에는 다른 채널 영상만 노출한다
const homeVideos = videos.filter((v) => v.source !== 'own').slice(0, 3);

// 홈에만 넣는 구조화 데이터 (site.ts 확정값만 사용, 창작 정보 없음)
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://hospital-ai-lab.com';
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_TITLE,
  url: siteUrl,
  logo: `${siteUrl}${withBase('/og-default.png')}`,
};
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  url: siteUrl,
};
---

<BaseLayout description={SITE_TAGLINE}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(orgJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd)} />

  <!-- 히어로: 브랜드 소개 + 가장 최근 글을 전면에 -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-intro">
        <p class="eyebrow">HOSPITAL AI LAB</p>
        <h1>의료 현장의 문제를<br />AI로 풉니다.</h1>
        <p class="tagline">
          17년간 병원 현장에서 쌓은 경험을 AI 활용과 연결합니다. 화려한 기술
          소개보다 "실제로 병원에서 쓸 수 있는가"를 먼저 묻습니다.
        </p>
        <div class="hero-actions">
          <a class="btn" href={withBase('/about/')}>연구소 소개 보기</a>
          <button type="button" class="btn ghost" id="bookmark-btn">⭐ 즐겨찾기 추가</button>
        </div>
        <p class="bookmark-hint" id="bookmark-hint" hidden></p>
      </div>

      {
        featured && (
          <a class="hero-featured" href={withBase(`/blog/${featured.id}/`)}>
            <div class="hf-meta">
              <span class="chip">{featured.data.category}</span>
              <span class="hf-label">가장 최근 글</span>
            </div>
            <h2 class="hf-title">{featured.data.title}</h2>
            <p class="hf-desc">{featured.data.description}</p>
            <span class="hf-more">이어 읽기 →</span>
          </a>
        )
      }
    </div>
  </section>

  <!-- 구독 안내 배너 (전면 배치) -->
  <section class="section">
    <div class="container">
      <div class="subscribe-band">
        <div>
          <h2>새 글과 AI 뉴스를 놓치지 마세요</h2>
          <p>
            매일 아침 자동으로 모으는 의료 AI 뉴스와 새 칼럼을 받아보세요.
            회원가입하면 병원 행정·간호 실무자를 위한 강의노트까지 볼 수 있습니다.
          </p>
        </div>
        <div class="band-actions">
          <a class="btn" href={withBase('/signup/')}>회원가입</a>
          <a class="btn ghost" href={withBase('/rss.xml')}>RSS 구독</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 최근 게시 소식: 칼럼·강의노트·AI로 만든 앱을 한 게시판에 모은다.
       블로그는 빌드 시점에 바로 나오고(무JS에서도 보임), 강의노트·AI 앱은
       페이지가 뜬 뒤 자바스크립트가 불러와 같은 목록에 합쳐 넣는다. -->
  {
    recentPosts.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>최근 게시 소식</h2>
          </div>
          <p class="feed-note">
            칼럼·강의노트·AI로 만든 앱 — 새로 올라온 순서대로 모았습니다.
            이 홈페이지는 지금도 계속 업데이트되고 있습니다.
          </p>
          <ul class="activity-feed" id="activity-feed">
            {recentPosts.map((post) => (
              <li class="feed-row" data-date={post.data.pubDate.toISOString()}>
                <span class="feed-badge feed-badge-blog">📝 칼럼</span>
                <a class="feed-title" href={withBase(`/blog/${post.id}/`)}>
                  {post.data.title}
                </a>
                <time class="feed-date">{formatDate(post.data.pubDate)}</time>
              </li>
            ))}
          </ul>
          <div class="feed-links">
            <a class="more" href={withBase('/blog/')}>블로그 전체 보기 →</a>
            <a class="more" href={withBase('/notes/')}>강의노트 보기 →</a>
            <a class="more" href={withBase('/ai-apps/')}>AI로 만든 앱 보기 →</a>
          </div>
        </div>
      </section>
    )
  }

  <!-- 최근 AI 뉴스 -->
  {
    recentNews.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>최근 AI 뉴스</h2>
            <a class="more" href={withBase('/news/')}>AI 뉴스 전체 보기 →</a>
          </div>
          <ul class="news-preview">
            {recentNews.map((item) => (
              <li>
                <a href={item.link} target="_blank" rel="noopener">
                  {item.title}
                  <span class="sr-only"> (새 탭으로 열림)</span>
                </a>
                {item.source && <span class="src">{item.source}</span>}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- 추천 강의 영상 -->
  {
    homeVideos.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-head">
            <h2>추천 강의 영상</h2>
            <a class="more" href={withBase('/youtube/')}>추천 영상 전체 보기 →</a>
          </div>
          <div class="grid-3">
            {homeVideos.map((v) => (
              <a class="video-card" href={v.url} target="_blank" rel="noopener">
                <img
                  src={`https://img.youtube.com/vi/${v.videoId}/hqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  width="480"
                  height="360"
                />
                <p class="video-title">
                  {v.title}
                  <span class="sr-only"> (유튜브, 새 탭으로 열림)</span>
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- 연구 분야 (소개 성격이라 콘텐츠 아래에 배치) -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>연구 분야</h2>
        <a class="more" href={withBase('/about/#research')}>전체 연구 분야 보기 →</a>
      </div>
      <div class="grid-3">
        {
          homeAreas.map((area) => (
            <article class="card">
              <ResearchIcon icon={area.icon} />
              <h3>{area.title}</h3>
              <p>{area.short}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 입문 가이드 안내 -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>AI 입문, 여기서 시작하세요</h2>
        <a class="more" href={withBase('/guide/')}>입문 가이드 전체 보기 →</a>
      </div>
      <div class="grid-3">
        <a class="card guide-card" href={withBase('/guide/')}>
          <h3>입문 가이드</h3>
          <p>책 대신 실전으로 — 다섯 단계 학습 사이클을 안내합니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/glossary/')}>
          <h3>의료 AI 용어 사전</h3>
          <p>제안서·회의에서 마주치는 용어를 항목별로 정리했습니다.</p>
        </a>
        <a class="card guide-card" href={withBase('/faq/')}>
          <h3>자주 묻는 질문</h3>
          <p>입문자가 실제로 궁금해하는 질문에 답합니다.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 문의 배너 -->
  <section class="section">
    <div class="container">
      <div class="contact-banner">
        <div>
          <h2>함께 고민하고 싶은 문제가 있으신가요?</h2>
          <p>연구 주제 제안, 협업, 콘텐츠에 대한 문의를 기다립니다.</p>
        </div>
        <a class="btn" href={withBase('/contact/')}>문의하기</a>
      </div>
    </div>
  </section>

  <!-- 개발 상태 표시: 이 홈페이지가 계속 업데이트되고 있음을 알린다.
       버전은 사람이 판단해 올리고, 날짜는 마지막 커밋에서 자동 계산된다. -->
  <p class="dev-status">
    🔧 이 홈페이지는 아직 계속 업데이트되고 있습니다 · v{SITE_VERSION} · 최근 업데이트 {lastUpdated}
  </p>
</BaseLayout>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  // "최근 게시 소식"에 강의노트·AI로 만든 앱을 더한다. 블로그는 이미
  // 빌드 시점에 목록에 들어가 있으므로, 여기서는 두 종류만 불러와
  // 같은 목록에 이어 붙이고 날짜순으로 다시 정렬한다.
  (async () => {
    const list = document.getElementById('activity-feed');
    if (!list || !SUPABASE_URL) return;

    const fmt = (iso) =>
      new Date(iso).toLocaleDateString('ko-KR', {
        timeZone: 'Asia/Seoul',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

    function addRow({ badgeClass, badgeLabel, title, dateIso, href }) {
      const li = document.createElement('li');
      li.className = 'feed-row';
      li.dataset.date = dateIso;

      const badge = document.createElement('span');
      badge.className = `feed-badge ${badgeClass}`;
      badge.textContent = badgeLabel;

      const titleEl = document.createElement('a');
      titleEl.className = 'feed-title';
      titleEl.href = href;
      titleEl.textContent = title;

      const dateEl = document.createElement('time');
      dateEl.className = 'feed-date';
      dateEl.textContent = fmt(dateIso);

      li.append(badge, titleEl, dateEl);
      list.appendChild(li);
    }

    try {
      const { createClient } = await import(
        'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.0/+esm'
      );
      const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      const notesUrl = new URL('notes/', location.href).pathname;
      const appsUrl = new URL('ai-apps/', location.href).pathname;

      const [{ data: notes }, { data: apps }] = await Promise.all([
        sb
          .from('lecture_notes')
          .select('id,title,created_at')
          .eq('published', true)
          .order('created_at', { ascending: false })
          .limit(3),
        sb
          .from('ai_apps')
          .select('id,title,created_at')
          .eq('published', true)
          .order('created_at', { ascending: false })
          .limit(3),
      ]);

      (notes || []).forEach((n) =>
        addRow({
          badgeClass: 'feed-badge-note',
          badgeLabel: '📚 강의노트',
          title: n.title,
          dateIso: n.created_at,
          href: notesUrl,
        })
      );
      (apps || []).forEach((a) =>
        addRow({
          badgeClass: 'feed-badge-app',
          badgeLabel: '🖼️ AI로 만든 앱',
          title: a.title,
          dateIso: a.created_at,
          href: appsUrl,
        })
      );

      // 합쳐진 목록을 날짜 최신순으로 다시 정렬하고, 너무 길어지지 않게
      // 상위 6개만 남긴다(나머지는 각 more 링크로 유도).
      const rows = [...list.querySelectorAll('.feed-row')].sort(
        (a, b) => new Date(b.dataset.date) - new Date(a.dataset.date)
      );
      rows.forEach((row) => list.appendChild(row));
      rows.slice(6).forEach((row) => row.remove());
    } catch {
      // 강의노트·AI 앱을 못 불러와도 블로그 목록은 이미 화면에 있으니
      // 조용히 넘어간다(레이아웃이 깨지지 않게).
    }
  })();
</script>

<script is:inline>
  // 브라우저 보안 정책상 웹페이지가 북마크를 자동으로 추가할 방법은 없다
  // (예전 IE의 window.external.AddFavorite 같은 API가 크롬엔 아예 없음).
  // 그래서 버튼은 OS에 맞는 단축키를 즉시 안내하는 역할만 한다.
  (() => {
    const btn = document.getElementById('bookmark-btn');
    const hint = document.getElementById('bookmark-hint');
    if (!btn || !hint) return;
    const isMac = /Mac|iPhone|iPod|iPad/.test(navigator.platform || navigator.userAgent);
    const shortcut = isMac ? 'Cmd + D' : 'Ctrl + D';
    let hideTimer;
    btn.addEventListener('click', () => {
      hint.textContent = `⌨️ ${shortcut} 를 누르면 이 페이지가 즐겨찾기(북마크)에 추가됩니다. 브라우저 보안 정책상 버튼 클릭만으로 자동 추가는 되지 않습니다.`;
      hint.hidden = false;
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        hint.hidden = true;
      }, 7000);
    });
  })();
</script>

<style>
  /* ── 히어로 ── */
  .hero {
    padding-block: 4rem 3.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.75rem;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .hero h1 {
    margin-top: 0.75rem;
    font-size: clamp(1.9rem, 4.6vw, 2.8rem);
  }

  .hero .tagline {
    margin-top: 1.25rem;
    max-width: 34rem;
    font-size: 1.075rem;
    color: var(--color-muted);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .bookmark-hint {
    margin-top: 0.75rem;
    max-width: 30rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.65rem 0.9rem;
  }

  .bookmark-hint[hidden] {
    display: none;
  }

  /* 히어로 안의 최근 글 카드 */
  .hero-featured {
    display: block;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .hero-featured:hover {
    text-decoration: none;
    border-color: var(--color-primary);
    box-shadow: 0 6px 20px rgba(11, 83, 148, 0.08);
    transform: translateY(-2px);
  }

  .hf-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hf-label {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .hf-title {
    margin-top: 0.85rem;
    font-size: 1.4rem;
    line-height: 1.4;
  }

  .hf-desc {
    margin-top: 0.75rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hf-more {
    display: inline-block;
    margin-top: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── 섹션 공통 ── */
  .section {
    padding-block: 3.25rem 1rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-bottom: 1.75rem;
  }

  .section-head h2 {
    position: relative;
    padding-left: 0.85rem;
    font-size: 1.5rem;
  }

  /* 캐릿식 섹션 제목 강조 — 왼쪽 세로 악센트 바 */
  .section-head h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.18em;
    bottom: 0.18em;
    width: 4px;
    border-radius: 2px;
    background: var(--color-primary);
  }

  .more {
    font-size: 0.925rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .card h3 {
    margin-top: 1.1rem;
    font-size: 1.125rem;
  }

  .card p {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  /* 입문 가이드 안내 카드 (링크이므로 밑줄·색 규칙을 별도로 지정) */
  .guide-card {
    display: block;
    color: var(--color-text);
  }

  .guide-card:hover {
    text-decoration: none;
  }

  .guide-card:hover h3 {
    color: var(--color-primary);
  }

  /* 추천 영상 카드 */
  .video-card {
    display: block;
    color: var(--color-text);
  }

  .video-card:hover {
    text-decoration: none;
  }

  .video-card:hover .video-title {
    color: var(--color-primary);
  }

  .video-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .video-title {
    margin-top: 0.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
  }

  /* 최근 게시 소식 (블로그·강의노트·AI 앱 통합 게시판) */
  .feed-note {
    margin-top: -0.75rem;
    margin-bottom: 1.5rem;
    max-width: 40rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .feed-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-top: 1.25rem;
  }

