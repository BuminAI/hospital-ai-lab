---
import '../styles/global.css';
import {
  withBase,
  stripBase,
  SITE_TITLE,
  SITE_TAGLINE,
  CONTACT_EMAIL,
  YOUTUBE_CHANNEL_URL,
  DISCLAIMER,
  NAVER_SITE_VERIFICATION,
  GOOGLE_SITE_VERIFICATION,
  GOATCOUNTER_CODE,
} from '../utils/site';

interface Props {
  title?: string;
  description?: string;
  /** true면 검색엔진 색인에서 제외 (관리자 페이지 등) */
  noindex?: boolean;
  /** 소셜 공유 타입. 글 상세는 'article' */
  ogType?: 'website' | 'article';
  /** article일 때 발행일 (og·JSON-LD용) */
  pubDate?: Date;
  /** article일 때 분류(카테고리) */
  category?: string;
}

const {
  title,
  description = SITE_TAGLINE,
  noindex = false,
  ogType = 'website',
  pubDate,
  category,
} = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
// 소셜 공유 대표 이미지 (절대 URL 필요)
const ogImage = Astro.site
  ? new URL(withBase('/og-default.png'), Astro.site).href
  : withBase('/og-default.png');
// 디렉터리 URL은 끝 슬래시를 붙여 sitemap과 canonical을 일치시킨다.
const canonicalPath =
  Astro.url.pathname.endsWith('/') || /\.[a-z0-9]+$/i.test(Astro.url.pathname)
    ? Astro.url.pathname
    : `${Astro.url.pathname}/`;
const canonical = Astro.site ? new URL(canonicalPath, Astro.site) : Astro.url;
const currentPath = stripBase(Astro.url.pathname);

// "문의"는 상단에서 빼고 푸터·홈 하단 밴드로 옮겼다(메뉴 밀도 완화, 2026-07-12).
// 페이지(/contact/)와 주소는 그대로 유지된다.
const nav = [
  { href: '/', label: '홈' },
  { href: '/about/', label: '소개' },
  { href: '/blog/', label: '블로그' },
  { href: '/news/', label: 'AI 뉴스' },
  { href: '/gov-support/', label: '정부 지원사업' },
  { href: '/notes/', label: '강의노트' },
  { href: '/youtube/', label: '추천 영상' },
  { href: '/tips/', label: '실무 팁' },
  { href: '/guide/', label: '입문 가이드' },
];

// 푸터 사이트맵 — 상단 메뉴에 없는 진입로를 보강한다
const footerNav = [
  { href: '/guide/', label: '입문 가이드' },
  { href: '/glossary/', label: '의료 AI 용어 사전' },
  { href: '/faq/', label: '자주 묻는 질문' },
  { href: '/checklist/', label: 'AI 도입 체크리스트' },
  { href: '/contact/', label: '문의' },
  { href: '/login/', label: '회원 로그인' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href.replace(/\/$/, ''));
}

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {
      NAVER_SITE_VERIFICATION && (
        <meta name="naver-site-verification" content={NAVER_SITE_VERIFICATION} />
      )
    }
    {
      GOOGLE_SITE_VERIFICATION && (
        <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
      )
    }
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32.png')} />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <link
      rel="preload"
      href={withBase('/fonts/PretendardVariable.woff2')}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e141d" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={withBase('/rss.xml')}
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE_TITLE} />
    {
      ogType === 'article' && pubDate && (
        <meta property="article:published_time" content={pubDate.toISOString()} />
      )
    }
    {ogType === 'article' && category && <meta property="article:section" content={category} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      GOATCOUNTER_CODE && !noindex && (
        <script
          is:inline
          async
          data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
          src="https://gc.zgo.at/count.js"
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="site-name" href={withBase('/')}>
          <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="1" y="1" width="22" height="22" rx="6" fill="var(--color-primary)"></rect>
            <path
              d="M5.5 12h3.5l2-4 3 8 2-4h2.5"
              stroke="#fff"
              stroke-width="1.8"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          병원 AI 연구소
        </a>
        <button
          type="button"
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="primary-nav"
          aria-label="주 메뉴 열기/닫기"
        >
          <span class="menu-label">메뉴</span>
        </button>
        <nav id="primary-nav" aria-label="주 메뉴">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={withBase(item.href)}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <script is:inline>
      // 모바일 메뉴 토글. <details>는 최신 브라우저가 닫힌 상태의 자식을
      // content-visibility로 강제 숨겨 CSS display:block으로도 못 되돌리는
      // 경우가 있어, 버튼 클릭으로 클래스를 토글하는 방식으로 대체했다.
      (function () {
        var btn = document.querySelector('.nav-toggle');
        var nav = document.getElementById('primary-nav');
        if (!btn || !nav) return;
        function setOpen(open) {
          btn.setAttribute('aria-expanded', String(open));
          nav.classList.toggle('is-open', open);
        }
        btn.addEventListener('click', function () {
          setOpen(btn.getAttribute('aria-expanded') !== 'true');
        });
        document.addEventListener('click', function (e) {
          if (!btn.contains(e.target) && !nav.contains(e.target)) setOpen(false);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') setOpen(false);
        });
      })();
    </script>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <p class="footer-title">병원 AI 연구소 <span>Hospital AI Lab</span></p>
          <p class="footer-disclaimer">{DISCLAIMER}</p>
          <div class="footer-meta">
            <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
            <span aria-hidden="true">·</span>
            <a href={YOUTUBE_CHANNEL_URL} target="_blank" rel="noopener">
              유튜브 채널
              <span class="sr-only"> (새 탭으로 열림)</span>
            </a>
            <span aria-hidden="true">·</span>
            <a href={withBase('/rss.xml')}>새 글 자동 받기(RSS)</a>
            <span aria-hidden="true">·</span>
            <a href={withBase('/privacy/')}>개인정보 처리방침</a>
            <span aria-hidden="true">·</span>
            <span>© {year} 병원 AI 연구소</span>
          </div>
        </div>
        <nav class="footer-nav" aria-label="푸터">
          <p class="footer-nav-title">둘러보기</p>
          <ul>
            {
              footerNav.map((item) => (
                <li>
                  <a href={withBase(item.href)}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    background: var(--btn-bg);
    color: var(--btn-fg);
    font-weight: 600;
    padding: 0.6rem 1.1rem;
    border-radius: 0 0 8px 0;
  }

  .skip-link:focus {
    left: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: var(--header-bg);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    padding-block: 1.1rem;
  }

  /* 접이식 네비게이션: 데스크톱은 항상 펼침, 모바일은 '메뉴' 버튼으로 토글 */
  .nav-toggle {
    display: none;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
    background: var(--color-bg);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  /* 데스크톱: 항상 펼쳐 보인다 */
  #primary-nav {
    display: block;
  }

  .site-name {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.02em;
  }

  .site-name:hover {
    text-decoration: none;
    color: var(--color-primary);
  }

  #primary-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #primary-nav a {
    font-size: 0.95rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  #primary-nav a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  /* 활성 메뉴: 굵기 대신 밑줄 인디케이터 — 페이지 이동 시 글자폭 흔들림 방지 */
  #primary-nav a[aria-current='page'] {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.55em;
  }

  main {
    min-height: 60vh;
  }

  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-border);
    padding-block: 3rem;
    background: var(--color-surface);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 2rem 3rem;
  }

  @media (max-width: 40rem) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  .footer-nav-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    text-transform: uppercase;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0.85rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 1.5rem;
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .footer-nav a:hover {
    color: var(--color-primary);
  }

  .footer-title {
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-heading);
  }

  .footer-title span {
    font-weight: 500;
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-left: 0.35rem;
  }

  .footer-disclaimer {
    margin-top: 0.85rem;
    max-width: var(--prose-width);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .footer-meta {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .footer-meta a {
    color: var(--color-muted);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .footer-meta a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 40rem) {
    .header-inner {
      position: relative;
    }

    .nav-toggle {
      display: inline-block;
    }

    /* 모바일: 닫혀 있으면 메뉴 감춤 */
    #primary-nav {
      display: none;
    }

    /* 모바일: 열면 헤더 아래로 카드형 드롭다운 */
    #primary-nav.is-open {
      display: block;
      position: absolute;
      right: 0;
      top: calc(100% + 0.65rem);
      min-width: 12rem;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      padding: 0.5rem;
      z-index: 60;
    }

    #primary-nav.is-open ul {
      flex-direction: column;
      gap: 0;
    }

    #primary-nav.is-open li a {
      display: block;
      padding: 0.6rem 0.75rem;
      border-radius: 8px;
    }

    #primary-nav.is-open li a:hover,
    #primary-nav.is-open li a[aria-current='page'] {
      background: var(--color-primary-soft);
    }
  }
</style>
